@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 d-flex align-items-center justify-content-end gap-3">
            <!-- API 서버 상태 인디케이터 — 30초 폴링, 클릭 시 의존성별 상세 모달 -->
            <HealthIndicator />
            <!-- 운영 알림 종 아이콘 — 미확인 알림 수 30초 폴링 -->
            <NotificationBell />
            <!-- 로그인된 사용자 이름 및 로그아웃 버튼 표시 -->
            <AuthorizeView>
                <Authorized>
                    <span class="text-muted small">@context.User.Identity?.Name</span>
                    <a href="/logout" class="btn btn-sm btn-outline-secondary">로그아웃</a>
                </Authorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @*
                [빌드별 예외 처리]
                Debug: @Body를 그대로 렌더링 → 예외 발생 시 Blazor가 SignalR 회로를 끊고
                       상세 오류를 노출(DetailedErrors=true). 개발자가 즉시 포착 가능.
                Release: SafeErrorBoundary로 감싸 자식 컴포넌트의 모든 예외
                        (렌더링/라이프사이클/이벤트 핸들러)를 자동 catch.
                        Serilog 파일 로그 기록 + 사용자에게 친화적인 오류 카드 표시.
                        회로는 유지되므로 다른 페이지로 이동하면 정상 작동.
                [주의] #if DEBUG를 마크업에 직접 쓰면 텍스트로 렌더링되므로
                       @code 블록의 _isDebugBuild 상수를 @if로 참조한다.
            *@
            @if (_isDebugBuild)
            {
                @Body
            }
            else
            {
                <SafeErrorBoundary>
                    <ChildContent>
                        @Body
                    </ChildContent>
                    <ErrorContent>
                        <div class="alert alert-danger mt-3" role="alert">
                            <h5 class="alert-heading">오류가 발생했습니다</h5>
                            <p class="mb-2">문제가 반복되면 관리자에게 문의해주세요.</p>
                            <a href="." class="btn btn-primary btn-sm">새로고침</a>
                        </div>
                    </ErrorContent>
                </SafeErrorBoundary>
            }
        </article>
    </main>
</div>

@code {
    // 컴파일 타임에 결정되는 빌드 구분값 — 마크업에서 @if로 참조
#if DEBUG
    private const bool _isDebugBuild = true;
#else
    private const bool _isDebugBuild = false;
#endif
}

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
