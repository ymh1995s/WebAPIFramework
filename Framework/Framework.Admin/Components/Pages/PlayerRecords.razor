@page "/players"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@inject IHttpClientFactory HttpClientFactory

<PageTitle>플레이어 기록</PageTitle>

<h2>플레이어 기록 관리</h2>

<!-- 전체 목록 -->
<section class="mb-5">
    <h4>전체 목록</h4>
    @if (isLoading)
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>ID</th><th>닉네임</th><th>플레이 시간(초)</th><th>점수</th><th>등록일시</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < pageSize; i++)
                {
                    <tr class="skeleton-row">
                        <td><span class="skeleton-cell"></span></td>
                        <td><span class="skeleton-cell"></span></td>
                        <td><span class="skeleton-cell"></span></td>
                        <td><span class="skeleton-cell"></span></td>
                        <td><span class="skeleton-cell"></span></td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else if (pagedResult == null || !pagedResult.Items.Any())
    {
        <p>등록된 기록이 없습니다.</p>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>닉네임</th>
                    <th>플레이 시간(초)</th>
                    <th>점수</th>
                    <th>등록일시</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in pagedResult.Items)
                {
                    <tr>
                        <td>@r.Id</td>
                        <td>@r.Nickname</td>
                        <td>@r.PlayTime</td>
                        <td>@r.Score</td>
                        <td>@r.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- 페이지네이션 -->
        <div class="d-flex align-items-center gap-2">
            <button class="btn btn-outline-secondary btn-sm" @onclick="PrevPage" disabled="@(currentPage <= 1)">이전</button>
            <span>@currentPage / @pagedResult.TotalPages 페이지 (총 @pagedResult.TotalCount 건)</span>
            <button class="btn btn-outline-secondary btn-sm" @onclick="NextPage" disabled="@(currentPage >= pagedResult.TotalPages)">다음</button>
        </div>
    }
</section>

<!-- ID 조회 -->
<section class="mb-5">
    <h4>ID로 조회</h4>
    <div class="d-flex gap-2 mb-2">
        <input type="number" class="form-control w-auto" placeholder="ID 입력" @bind="searchId" />
        <button class="btn btn-secondary" @onclick="SearchById">조회</button>
    </div>
    @if (searchResult != null)
    {
        <table class="table table-bordered w-auto">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>닉네임</th>
                    <th>플레이 시간(초)</th>
                    <th>점수</th>
                    <th>등록일시</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>@searchResult.Id</td>
                    <td>@searchResult.Nickname</td>
                    <td>@searchResult.PlayTime</td>
                    <td>@searchResult.Score</td>
                    <td>@searchResult.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                </tr>
            </tbody>
        </table>
    }
    @if (searchError != null)
    {
        <p class="text-danger">@searchError</p>
    }
</section>

<!-- 신규 입력 -->
<section class="mb-5">
    <h4>신규 입력</h4>
    <div class="d-flex flex-column gap-2" style="max-width: 320px;">
        <input type="text" class="form-control" placeholder="닉네임" @bind="newNickname" />
        <input type="number" class="form-control" placeholder="플레이 시간(초)" @bind="newPlayTime" step="0.1" />
        <input type="number" class="form-control" placeholder="점수" @bind="newScore" />
        <button class="btn btn-primary" @onclick="CreateRecord">등록</button>
    </div>
    @if (createMessage != null)
    {
        <p class="mt-2 @(createSuccess ? "text-success" : "text-danger")">@createMessage</p>
    }
</section>

<style>
    .skeleton-cell {
        display: inline-block;
        width: 80%;
        height: 1rem;
        background: linear-gradient(90deg, #e0e0e0 25%, #f0f0f0 50%, #e0e0e0 75%);
        background-size: 200% 100%;
        animation: shimmer 1.2s infinite;
        border-radius: 4px;
    }
    @@keyframes shimmer {
        0% { background-position: 200% 0; }
        100% { background-position: -200% 0; }
    }
</style>

@code {
    // 전체 목록 (페이지네이션)
    private PagedResultDto? pagedResult;
    private int currentPage = 1;
    private const int pageSize = 20;
    private bool isLoading = true;

    // ID 조회
    private int searchId;
    private PlayerRecordDto? searchResult;
    private string? searchError;

    // 신규 입력
    private string newNickname = "";
    private float newPlayTime;
    private int newScore;
    private string? createMessage;
    private bool createSuccess;

    // ★ 개선 전: OnInitializedAsync에서 전체 데이터를 한 번에 로드 → 데이터 많을수록 페이지 진입 블로킹
    //   protected override async Task OnInitializedAsync() { await LoadAll(); }
    //   private async Task LoadAll() { allRecords = await client.GetFromJsonAsync<List<PlayerRecordDto>>("api/playerrecords"); }
    //
    // ★ 개선 후: OnAfterRenderAsync(firstRender)로 페이지 먼저 렌더링 → 스켈레톤 표시 → 데이터 로드 후 StateHasChanged()
    //   OnInitializedAsync에서 await하면 렌더링 자체가 블로킹되어 스켈레톤이 보이지 않음
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadPaged();
            StateHasChanged();
        }
    }

    private async Task LoadPaged()
    {
        isLoading = true;
        var client = HttpClientFactory.CreateClient("ApiClient");
        pagedResult = await client.GetFromJsonAsync<PagedResultDto>($"api/playerrecords?page={currentPage}&pageSize={pageSize}");
        isLoading = false;
    }

    private async Task PrevPage()
    {
        if (currentPage > 1) { currentPage--; await LoadPaged(); }
    }

    private async Task NextPage()
    {
        if (pagedResult != null && currentPage < pagedResult.TotalPages) { currentPage++; await LoadPaged(); }
    }

    private async Task SearchById()
    {
        searchResult = null;
        searchError = null;

        var client = HttpClientFactory.CreateClient("ApiClient");
        var response = await client.GetAsync($"api/playerrecords/{searchId}");

        if (response.IsSuccessStatusCode)
            searchResult = await response.Content.ReadFromJsonAsync<PlayerRecordDto>();
        else
            searchError = $"ID {searchId}에 해당하는 기록을 찾을 수 없습니다.";
    }

    private async Task CreateRecord()
    {
        createMessage = null;

        if (string.IsNullOrWhiteSpace(newNickname))
        {
            createMessage = "닉네임을 입력해주세요.";
            createSuccess = false;
            return;
        }

        var client = HttpClientFactory.CreateClient("ApiClient");
        var payload = new { Nickname = newNickname, PlayTime = newPlayTime, Score = newScore };
        var response = await client.PostAsJsonAsync("api/playerrecords", payload);

        if (response.IsSuccessStatusCode)
        {
            createMessage = "등록되었습니다.";
            createSuccess = true;
            newNickname = "";
            newPlayTime = 0;
            newScore = 0;
            await LoadPaged(); // 목록 갱신
        }
        else
        {
            createMessage = "등록에 실패했습니다.";
            createSuccess = false;
        }
    }

    // API 응답 매핑용 로컬 DTO
    // record 미사용 시 아래와 동일:
    /* private class PlayerRecordDto
    {
        public int Id { get; init; }
        public string Nickname { get; init; } = "";
        public float PlayTime { get; init; }
        public int Score { get; init; }
        public DateTime CreatedAt { get; init; }
    } */
    private record PlayerRecordDto(int Id, string Nickname, float PlayTime, int Score, DateTime CreatedAt);

    // 페이지네이션 응답 매핑용 로컬 DTO
    private record PagedResultDto(List<PlayerRecordDto> Items, int TotalCount, int Page, int PageSize)
    {
        public int TotalPages => (int)Math.Ceiling((double)TotalCount / PageSize);
    }
}
