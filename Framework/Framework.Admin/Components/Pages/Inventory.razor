@page "/inventory"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inherits SafeComponentBase
@inject IHttpClientFactory HttpClientFactory
@using Framework.Admin.Constants

<PageTitle>인벤토리 조회</PageTitle>

<h2>플레이어 인벤토리 조회</h2>

<section class="mb-4">
    <div class="d-flex gap-2 align-items-center mb-3">
        <input type="number" class="form-control w-auto" placeholder="플레이어 ID" @bind="playerId" />
        <button class="btn btn-primary" @onclick="LoadInventory">조회</button>
    </div>

    @if (isLoading)
    {
        <p>불러오는 중...</p>
    }
    else if (items == null)
    {
        <p class="text-muted">플레이어 ID를 입력하고 조회하세요.</p>
    }
    else if (!items.Any())
    {
        <p>보유 아이템이 없습니다.</p>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>아이템 ID</th>
                    <th>아이템명</th>
                    <th>종류</th>
                    <th>수량</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in items)
                {
                    <tr>
                        <td>@item.ItemId</td>
                        <td>@item.ItemName</td>
                        <td>@item.ItemType</td>
                        <td>@item.Quantity</td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (errorMessage != null)
    {
        <p class="text-danger">@errorMessage</p>
    }
</section>

@code {
    private int playerId;
    private bool isLoading;
    private List<PlayerItemDto>? items;
    private string? errorMessage;

    private async Task LoadInventory()
    {
        if (playerId <= 0)
        {
            errorMessage = "유효한 플레이어 ID를 입력하세요.";
            return;
        }

        isLoading = true;
        errorMessage = null;

        var client = HttpClientFactory.CreateClient("ApiClient");
        var response = await client.GetAsync(ApiRoutes.Players.Items(playerId));

        if (response.IsSuccessStatusCode)
            items = await response.Content.ReadFromJsonAsync<List<PlayerItemDto>>();
        else
            errorMessage = $"조회 실패: {response.StatusCode}";

        isLoading = false;
    }

    // API 응답 매핑용 로컬 DTO
    private record PlayerItemDto(int ItemId, string ItemName, string ItemType, int Quantity);
}
