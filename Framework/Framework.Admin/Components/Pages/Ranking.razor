@page "/ranking"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@inject IHttpClientFactory HttpClientFactory

<PageTitle>랭킹 조회</PageTitle>

<h2>랭킹 조회</h2>

<section class="mb-4">
    <div class="d-flex gap-2 align-items-center mb-3">
        <label class="form-label mb-0">상위</label>
        <input type="number" class="form-control w-auto" style="width:100px !important;" @bind="count" min="1" max="1000" />
        <label class="form-label mb-0">명</label>
        <button class="btn btn-primary" @onclick="LoadRanking">조회</button>
    </div>

    @if (isLoading)
    {
        <p>불러오는 중...</p>
    }
    else if (rankings == null)
    {
        <p class="text-muted">조회 버튼을 눌러주세요.</p>
    }
    else if (!rankings.Any())
    {
        <p>랭킹 데이터가 없습니다.</p>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>순위</th>
                    <th>플레이어 ID</th>
                    <th>닉네임</th>
                    <th>최고 점수</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in rankings)
                {
                    <tr>
                        <td>@r.Rank</td>
                        <td>@r.PlayerId</td>
                        <td>@r.Nickname</td>
                        <td>@r.BestScore</td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (errorMessage != null)
    {
        <p class="text-danger">@errorMessage</p>
    }
</section>

@code {
    private int count = 100;
    private bool isLoading;
    private List<RankingDto>? rankings;
    private string? errorMessage;

    private async Task LoadRanking()
    {
        isLoading = true;
        errorMessage = null;

        var client = HttpClientFactory.CreateClient("ApiClient");
        var response = await client.GetAsync($"api/ranking/top?count={count}");

        if (response.IsSuccessStatusCode)
            rankings = await response.Content.ReadFromJsonAsync<List<RankingDto>>();
        else
            errorMessage = $"조회 실패: {response.StatusCode}";

        isLoading = false;
    }

    // API 응답 매핑용 로컬 DTO
    private record RankingDto(int Rank, int PlayerId, string Nickname, int BestScore);
}
