@page "/login"
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]

<PageTitle>Admin 로그인</PageTitle>

<div style="max-width: 360px; margin: 80px auto;">
    <h3 class="mb-4">Admin 로그인</h3>

    @if (showError)
    {
        <!-- 비밀번호 불일치 시 오류 메시지 표시 -->
        <div class="alert alert-danger">비밀번호가 올바르지 않습니다.</div>
    }

    <!-- /admin-login 엔드포인트로 POST 전송 -->
    <form method="post" action="/admin-login">
        <div class="mb-3">
            <label class="form-label">비밀번호</label>
            <input type="password" name="password" class="form-control" autofocus />
        </div>
        <button type="submit" class="btn btn-primary w-100">로그인</button>
    </form>
</div>

@code {
    // SSR 컴포넌트에서 HttpContext 접근 - 쿼리스트링 확인용
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    // ?error=1 쿼리스트링이 있으면 오류 메시지 표시
    private bool showError => HttpContext?.Request.Query.ContainsKey("error") == true;
}
