@page "/iap-purchases"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inherits SafeComponentBase
@using Framework.Admin.Constants

<PageTitle>인앱결제 구매 이력</PageTitle>

<h2 class="mb-2">인앱결제 구매 이력</h2>

<div class="alert alert-info py-2 small mb-3">
    <p class="mb-1">플레이어의 인앱결제 구매 이력을 조회합니다. 환불 감시를 위해 <strong>Refunded</strong> 상태 행은 빨간색으로 강조됩니다.</p>
    <p class="mb-0">PurchaseToken은 앞 20자만 표시됩니다.</p>
</div>

<!-- 검색 필터 카드 -->
<section class="card mb-3">
    <div class="card-header py-2"><strong>검색 필터</strong></div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-2">
                <label class="form-label small mb-1">PlayerId</label>
                <input type="number" class="form-control form-control-sm" @bind="filterPlayerId"
                       placeholder="전체" />
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-1">스토어</label>
                <select class="form-select form-select-sm" @bind="filterStore">
                    <option value="">전체</option>
                    @foreach (var s in StoreOptions)
                    {
                        <option value="@s.Value">@s.Label</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small mb-1">ProductId</label>
                <input type="text" class="form-control form-control-sm" @bind="filterProductId"
                       placeholder="전체" />
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-1">상태</label>
                <select class="form-select form-select-sm" @bind="filterStatus">
                    <option value="">전체</option>
                    @foreach (var st in StatusOptions)
                    {
                        <option value="@st.Value">@st.Label</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small mb-1">구매 기간 (From)</label>
                <input type="datetime-local" class="form-control form-control-sm" @bind="filterFrom" />
            </div>
            <div class="col-md-3">
                <label class="form-label small mb-1">구매 기간 (To)</label>
                <input type="datetime-local" class="form-control form-control-sm" @bind="filterTo" />
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-1">페이지 크기</label>
                <input type="number" class="form-control form-control-sm" @bind="pageSize" min="10" max="100" />
            </div>
        </div>
    </div>
    <div class="card-footer py-2 d-flex gap-2">
        <button class="btn btn-primary btn-sm" @onclick="Search">조회</button>
        <button class="btn btn-outline-secondary btn-sm" @onclick="Reset">초기화</button>
    </div>
</section>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger py-2 small">@errorMessage</div>
}

@if (isLoading)
{
    <p class="text-muted">불러오는 중...</p>
}
else if (items == null)
{
    <p class="text-muted">상단 필터를 설정한 후 <strong>조회</strong> 버튼을 눌러주세요.</p>
}
else if (!items.Any())
{
    <p class="text-muted">조건에 맞는 구매 이력이 없습니다.</p>
}
else
{
    <div class="d-flex align-items-center mb-2">
        <span class="small text-muted ms-auto">총 <strong>@totalCount</strong> 건</span>
    </div>

    <table class="table table-sm table-hover">
        <thead>
            <tr>
                <th>ID</th>
                <th>PlayerId</th>
                <th>스토어</th>
                <th>ProductId</th>
                <th>PurchaseToken (앞 20자)</th>
                <th>상태</th>
                <th>구매 시각</th>
                <th>보상 지급</th>
                <th>환불 시각</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in items)
            {
                <!-- Refunded 행 전체 빨간색 강조 — 환불 감시 목적 -->
                <tr class="@(p.StatusValue == 3 ? "table-danger" : "")">
                    <td>@p.Id</td>
                    <td>@p.PlayerId</td>
                    <td><span class="badge bg-primary">@p.StoreLabel</span></td>
                    <td><code>@p.ProductId</code></td>
                    <td><code title="@p.PurchaseToken">@p.PurchaseTokenShort</code></td>
                    <td>@StatusBadge(p.StatusValue)</td>
                    <td>@(p.PurchaseTimeUtc?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                    <td>@(p.GrantedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                    <td>@(p.RefundedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                </tr>
            }
        </tbody>
    </table>

    <!-- 페이지네이션 -->
    <div class="d-flex gap-2 align-items-center">
        <button class="btn btn-outline-secondary btn-sm" @onclick="PrevPage" disabled="@(page <= 1)">이전</button>
        <span class="small">@(page) / @(TotalPages) 페이지</span>
        <button class="btn btn-outline-secondary btn-sm" @onclick="NextPage" disabled="@(page >= TotalPages)">다음</button>
    </div>
}

@* Status 뱃지 렌더 함수 — MarkupString 반환 *@
@code {
    private MarkupString StatusBadge(int status) => status switch
    {
        0 => (MarkupString)"<span class='badge bg-warning text-dark'>Pending</span>",
        1 => (MarkupString)"<span class='badge bg-primary'>Verified</span>",
        2 => (MarkupString)"<span class='badge bg-success'>Granted</span>",
        3 => (MarkupString)"<span class='badge bg-danger'>Refunded</span>",
        4 => (MarkupString)"<span class='badge bg-danger'>Failed</span>",
        _ => (MarkupString)$"<span class='badge bg-secondary'>{status}</span>"
    };
}
