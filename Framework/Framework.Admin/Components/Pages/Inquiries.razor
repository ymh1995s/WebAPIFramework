@page "/inquiries"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inherits SafeComponentBase
@inject IHttpClientFactory HttpClientFactory
@using Framework.Admin.Constants

<PageTitle>소원수리함</PageTitle>

<div class="d-flex align-items-center gap-3 mb-3">
    <h2 class="mb-0">소원수리함</h2>
    <button class="btn btn-outline-secondary btn-sm" @onclick="LoadInquiries">새로고침</button>
</div>

@if (isLoading)
{
    <p>불러오는 중...</p>
}
else if (inquiries.Count == 0)
{
    <p class="text-muted">접수된 문의가 없습니다.</p>
}
else
{
    <table class="table table-bordered table-sm">
        <thead>
            <tr>
                <th style="width:60px">ID</th>
                <th style="width:80px">PlyrID</th>
                <th style="width:120px">닉네임</th>
                <th>내용</th>
                <th style="width:80px">답변</th>
                <th style="width:160px">접수일</th>
                <th style="width:80px"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in inquiries)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.PlayerId</td>
                    <td>@item.PlayerNickname</td>
                    <td style="white-space:pre-wrap">@item.Content</td>
                    <td>
                        <span class="badge @(item.AdminReply != null ? "bg-success" : "bg-secondary")">
                            @(item.AdminReply != null ? "답변완료" : "미답변")
                        </span>
                    </td>
                    <td class="text-muted small">@item.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                    <td>
                        <button class="btn btn-outline-primary btn-sm"
                                @onclick="() => OpenReply(item)">
                            @(item.AdminReply != null ? "수정" : "답변")
                        </button>
                    </td>
                </tr>
                @if (replyingId == item.Id)
                {
                    <tr class="table-light">
                        <td colspan="7">
                            <div class="p-2">
                                @if (item.AdminReply != null)
                                {
                                    <p class="text-muted small mb-1">기존 답변: @item.AdminReply</p>
                                }
                                <div class="d-flex gap-2 align-items-start">
                                    <textarea class="form-control form-control-sm" rows="2"
                                              placeholder="답변 내용 입력" @bind="replyContent"
                                              style="max-width:500px;"></textarea>
                                    <button class="btn btn-success btn-sm" @onclick="() => SubmitReply(item.Id)">저장</button>
                                    <button class="btn btn-outline-secondary btn-sm" @onclick="CloseReply">취소</button>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
}

@if (errorMessage != null)
{
    <p class="text-danger">@errorMessage</p>
}

@code {
    // 문의 목록 상태
    private List<InquiryAdminDto> inquiries = [];
    private bool isLoading = true;
    private string? errorMessage;

    // 답변 폼 상태
    private int? replyingId;
    private string replyContent = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await SafeExecute(LoadInquiries, msg => errorMessage = msg);
            StateHasChanged();
        }
    }

    // 전체 문의 목록 조회
    private async Task LoadInquiries()
    {
        isLoading = true;
        errorMessage = null;
        var client = HttpClientFactory.CreateClient("ApiClient");
        var response = await client.GetAsync(ApiRoutes.AdminInquiries.Collection);

        if (response.IsSuccessStatusCode)
            inquiries = await response.Content.ReadFromJsonAsync<List<InquiryAdminDto>>() ?? [];
        else
            errorMessage = "문의 목록 조회에 실패했습니다.";

        isLoading = false;
    }

    // 답변 폼 열기 — 기존 답변이 있으면 편집 필드에 미리 채움
    private void OpenReply(InquiryAdminDto item)
    {
        replyingId = item.Id;
        replyContent = item.AdminReply ?? "";
    }

    private void CloseReply()
    {
        replyingId = null;
        replyContent = "";
    }

    // 답변 저장
    private async Task SubmitReply(int id)
    {
        errorMessage = null;
        if (string.IsNullOrWhiteSpace(replyContent)) return;

        var client = HttpClientFactory.CreateClient("ApiClient");
        var response = await client.PostAsJsonAsync(
            ApiRoutes.AdminInquiries.Reply(id),
            new { Reply = replyContent });

        if (response.IsSuccessStatusCode)
        {
            CloseReply();
            await LoadInquiries();
        }
        else
        {
            errorMessage = "답변 저장에 실패했습니다.";
        }
    }

    // Admin DTO — API 응답 역직렬화용 로컬 레코드
    private record InquiryAdminDto(int Id, int PlayerId, string PlayerNickname, string Content, string? AdminReply, DateTime? RepliedAt, DateTime CreatedAt);
}
