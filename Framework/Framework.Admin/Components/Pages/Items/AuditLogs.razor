@page "/audit-logs"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inherits SafeComponentBase
@using Framework.Admin.Constants

<PageTitle>아이템 변동 로그</PageTitle>

<h2>아이템 변동 로그</h2>

<!-- 필터 폼 -->
<section class="mb-3">
    <div class="d-flex gap-2 align-items-end flex-wrap">
        <div>
            <label class="form-label small">플레이어 ID</label>
            <input type="number" class="form-control form-control-sm" @bind="filterPlayerId" style="width:110px" />
        </div>
        <div>
            <label class="form-label small">아이템 ID</label>
            <input type="number" class="form-control form-control-sm" @bind="filterItemId" style="width:110px" />
        </div>
        <div>
            <label class="form-label small">시작 (KST)</label>
            <input type="datetime-local" class="form-control form-control-sm" @bind="filterFromLocal" />
        </div>
        <div>
            <label class="form-label small">종료 (KST)</label>
            <input type="datetime-local" class="form-control form-control-sm" @bind="filterToLocal" />
        </div>
        <div>
            <label class="form-label small">이상치</label>
            <select class="form-select form-select-sm" @bind="filterAnomaly" style="width:110px">
                <option value="">전체</option>
                <option value="true">이상치만</option>
                <option value="false">정상만</option>
            </select>
        </div>
        <div>
            <label class="form-label small">페이지 크기</label>
            <input type="number" class="form-control form-control-sm" @bind="pageSize" style="width:90px" />
        </div>
        <button class="btn btn-primary btn-sm" @onclick="Search">조회</button>
        <button class="btn btn-outline-secondary btn-sm" @onclick="Reset">초기화</button>
    </div>
</section>

@if (isLoading)
{
    <p>불러오는 중...</p>
}
else if (result == null)
{
    <p class="text-muted">조회 버튼을 눌러주세요.</p>
}
else if (!result.Items.Any())
{
    <p class="text-muted">조건에 맞는 감사 로그가 없습니다.</p>
}
else
{
    <table class="table table-sm table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>플레이어</th>
                <th>아이템</th>
                <th>사유</th>
                <th>변동량</th>
                <th>Before → After</th>
                <th>이상치</th>
                <th>발생 (KST)</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var log in result.Items)
            {
                <tr class="@(log.IsAnomaly ? "table-warning" : "")">
                    <td>@log.Id</td>
                    <td>@log.PlayerId</td>
                    <td>@log.ItemId (@log.ItemName)</td>
                    <td>@log.Reason</td>
                    <td class="@(log.ChangeAmount >= 0 ? "text-success" : "text-danger")">
                        @(log.ChangeAmount >= 0 ? "+" : "")@log.ChangeAmount
                    </td>
                    <td>@log.BalanceBefore → @log.BalanceAfter</td>
                    <td>
                        @if (log.IsAnomaly)
                        {
                            <span class="badge bg-warning text-dark">이상치</span>
                        }
                    </td>
                    <td class="small">@ToKst(log.CreatedAt)</td>
                </tr>
            }
        </tbody>
    </table>

    <!-- 페이지네이션 -->
    <div class="d-flex gap-2 align-items-center">
        <button class="btn btn-outline-secondary btn-sm" @onclick="PrevPage" disabled="@(page <= 1)">이전</button>
        <span class="small">@(page) / @result.TotalPages (총 @result.TotalCount 건)</span>
        <button class="btn btn-outline-secondary btn-sm" @onclick="NextPage" disabled="@(page >= result.TotalPages)">다음</button>
    </div>
}

@if (errorMessage != null)
{
    <p class="text-danger mt-2">@errorMessage</p>
}
