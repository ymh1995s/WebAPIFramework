@page "/reward-slots"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inherits SafeComponentBase
@inject IHttpClientFactory HttpClientFactory
@using Framework.Admin.Constants
@using System.Net.Http.Json

<PageTitle>보상 슬롯 편집</PageTitle>

<h2>보상 슬롯 편집</h2>
<p class="text-muted">
    Current = 이번 달 활성 슬롯 / Next = 다음 달 예약 슬롯<br />
    월 전환 시 Next → Current 자동 복사됩니다. Admin이 Next를 수정하지 않으면 다음 달도 같은 보상이 반복됩니다.
</p>

<!-- ────────────── 탭 선택 ────────────── -->
<ul class="nav nav-tabs mb-3">
    <li class="nav-item">
        <button class="nav-link @(activeTab == "current" ? "active" : "")"
                @onclick='() => SwitchTab("current")'>
            Current (이번 달)
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(activeTab == "next" ? "active" : "")"
                @onclick='() => SwitchTab("next")'>
            Next (다음 달 예약)
        </button>
    </li>
</ul>

<!-- ────────────── 슬롯 테이블 ────────────── -->
@if (loading)
{
    <p>불러오는 중...</p>
}
else if (errorMessage != null)
{
    <p class="text-danger">@errorMessage</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-bordered table-sm align-middle" style="max-width:600px;">
            <thead class="table-light">
                <tr>
                    <th style="width:60px;">Day</th>
                    <th>아이템</th>
                    <th style="width:90px;">수량</th>
                    <th style="width:80px;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in slotRows)
                {
                    <tr>
                        <td class="text-center fw-bold">@row.Day</td>
                        <td>
                            <!-- 아이템 드롭다운 (없음 선택 시 보상 없음) -->
                            <select class="form-select form-select-sm"
                                    value="@(row.EditItemId?.ToString() ?? "")"
                                    @onchange="e => row.EditItemId = string.IsNullOrEmpty(e.Value?.ToString()) ? null : int.Parse(e.Value.ToString()!)">
                                <option value="">보상 없음</option>
                                @foreach (var item in itemList)
                                {
                                    <option value="@item.Id">@item.Name</option>
                                }
                            </select>
                        </td>
                        <td>
                            <input type="number" class="form-control form-control-sm" min="0"
                                   @bind="row.EditItemCount" disabled="@(!row.EditItemId.HasValue)" />
                        </td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-primary"
                                    @onclick="() => SaveDay(row)"
                                    disabled="@row.Saving">
                                @(row.Saving ? "저장중..." : "저장")
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (saveMessage != null)
    {
        <p class="mt-2 @(saveSuccess ? "text-success" : "text-danger")">@saveMessage</p>
    }
}

@code {
    // 현재 활성 탭 ("current" 또는 "next")
    private string activeTab = "current";

    // 로딩·에러 상태
    private bool loading = true;
    private string? errorMessage;

    // 저장 완료 메시지
    private string? saveMessage;
    private bool saveSuccess;

    // 슬롯 행 편집 모델 목록 (Day 1~28)
    private List<SlotRowModel> slotRows = new();

    // 아이템 드롭다운 목록
    private List<ItemOption> itemList = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await SafeExecute(LoadAllAsync, msg => { errorMessage = msg; loading = false; });
            StateHasChanged();
        }
    }

    // 아이템 목록 + 현재 탭 슬롯 데이터 병렬 로드
    private async Task LoadAllAsync()
    {
        loading = true;
        errorMessage = null;

        var client = HttpClientFactory.CreateClient("ApiClient");

        var itemTask = client.GetFromJsonAsync<List<ItemOption>>(ApiRoutes.AdminItems.Collection);
        var slotTask = client.GetFromJsonAsync<List<SlotDayDto>>(ApiRoutes.AdminDailyRewardSlots.Slot(activeTab));

        await Task.WhenAll(itemTask, slotTask);

        itemList = itemTask.Result ?? new();
        slotRows = (slotTask.Result ?? new()).Select(dto => new SlotRowModel
        {
            Day = dto.Day,
            EditItemId = dto.ItemId,
            EditItemCount = dto.ItemCount
        }).ToList();

        loading = false;
    }

    // 탭 전환 — 데이터 재로드
    private async Task SwitchTab(string tab)
    {
        activeTab = tab;
        saveMessage = null;
        await SafeExecute(LoadAllAsync, msg => { errorMessage = msg; loading = false; });
        StateHasChanged();
    }

    // 특정 Day 저장
    private async Task SaveDay(SlotRowModel row)
    {
        row.Saving = true;
        saveMessage = null;
        StateHasChanged();

        try
        {
            var client = HttpClientFactory.CreateClient("ApiClient");
            // ItemId 없으면 ItemCount도 0으로 전송
            var payload = new
            {
                ItemId = row.EditItemId,
                ItemCount = row.EditItemId.HasValue ? row.EditItemCount : 0
            };
            var response = await client.PutAsJsonAsync(
                ApiRoutes.AdminDailyRewardSlots.SlotDay(activeTab, row.Day), payload);

            saveSuccess = response.IsSuccessStatusCode;
            saveMessage = saveSuccess
                ? $"Day {row.Day} 저장 완료."
                : $"Day {row.Day} 저장 실패.";

            // 저장 성공 시 EditItemCount도 동기화
            if (saveSuccess && !row.EditItemId.HasValue)
                row.EditItemCount = 0;
        }
        catch (Exception ex)
        {
            saveSuccess = false;
            saveMessage = $"저장 중 오류: {ex.Message}";
        }
        finally
        {
            row.Saving = false;
            StateHasChanged();
        }
    }

    // ─── 내부 모델 ──────────────────────────────────

    // 슬롯 행 편집 상태 모델
    private class SlotRowModel
    {
        public int Day { get; set; }
        public int? EditItemId { get; set; }
        public int EditItemCount { get; set; }
        public bool Saving { get; set; }
    }

    // API 응답 역직렬화용 DTO
    private record SlotDayDto(string Slot, int Day, int? ItemId, int ItemCount, DateTime UpdatedAt);
    private record ItemOption(int Id, string Name, string Type, bool IsDeleted);
}
