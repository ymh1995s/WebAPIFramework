@page "/inquiries"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inherits SafeComponentBase
@using Framework.Admin.Constants

<PageTitle>문의 목록</PageTitle>

<div class="d-flex align-items-center gap-3 mb-3">
    <h2 class="mb-0">문의 목록</h2>
    <button class="btn btn-outline-secondary btn-sm" @onclick="LoadInquiries">새로고침</button>
</div>

@if (isLoading)
{
    <p>불러오는 중...</p>
}
else if (inquiries.Count == 0)
{
    <p class="text-muted">접수된 문의가 없습니다.</p>
}
else
{
    <table class="table table-bordered table-sm">
        <thead>
            <tr>
                <th style="width:60px">ID</th>
                <th style="width:80px">PlyrID</th>
                <th style="width:120px">닉네임</th>
                <th>내용</th>
                <th style="width:80px">답변</th>
                <th style="width:160px">접수일</th>
                <th style="width:80px"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in inquiries)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.PlayerId</td>
                    <td>@item.PlayerNickname</td>
                    <td style="white-space:pre-wrap">@item.Content</td>
                    <td>
                        <span class="badge @(item.AdminReply != null ? "bg-success" : "bg-secondary")">
                            @(item.AdminReply != null ? "답변완료" : "미답변")
                        </span>
                    </td>
                    <td class="text-muted small">@item.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                    <td>
                        <button class="btn btn-outline-primary btn-sm"
                                @onclick="() => OpenReply(item)">
                            @(item.AdminReply != null ? "수정" : "답변")
                        </button>
                    </td>
                </tr>
                @if (replyingId == item.Id)
                {
                    <tr class="table-light">
                        <td colspan="7">
                            <div class="p-2">
                                @if (item.AdminReply != null)
                                {
                                    <p class="text-muted small mb-1">기존 답변: @item.AdminReply</p>
                                }
                                <div class="d-flex gap-2 align-items-start">
                                    <textarea class="form-control form-control-sm" rows="2"
                                              placeholder="답변 내용 입력" @bind="replyContent"
                                              style="max-width:500px;"></textarea>
                                    <button class="btn btn-success btn-sm" @onclick="() => SubmitReply(item.Id)">저장</button>
                                    <button class="btn btn-outline-secondary btn-sm" @onclick="CloseReply">취소</button>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
}

@if (errorMessage != null)
{
    <p class="text-danger">@errorMessage</p>
}
