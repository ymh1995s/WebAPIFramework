@page "/players"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inherits SafeComponentBase
@inject IHttpClientFactory HttpClientFactory
@using Framework.Admin.Constants

<PageTitle>플레이어 관리</PageTitle>

<h2>플레이어 관리</h2>

<!-- 플레이어 목록 -->
<section class="mb-5">
    <h4>플레이어 목록</h4>
    @if (isLoading)
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>ID</th><th>PublicId</th><th>DeviceId</th><th>닉네임</th><th>Google 연동</th><th>생성일</th><th>마지막 로그인</th><th>밴 상태</th><th>삭제됨</th><th>병합 대상 ID</th><th>관리</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < pageSize; i++)
                {
                    <tr class="skeleton-row">
                        <td><span class="skeleton-cell"></span></td>
                        <td><span class="skeleton-cell"></span></td>
                        <td><span class="skeleton-cell"></span></td>
                        <td><span class="skeleton-cell"></span></td>
                        <td><span class="skeleton-cell"></span></td>
                        <td><span class="skeleton-cell"></span></td>
                        <td><span class="skeleton-cell"></span></td>
                        <td><span class="skeleton-cell"></span></td>
                        <td><span class="skeleton-cell"></span></td>
                        <td><span class="skeleton-cell"></span></td>
                        <td><span class="skeleton-cell"></span></td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else if (pagedResult == null || !pagedResult.Items.Any())
    {
        <p>등록된 플레이어가 없습니다.</p>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>PublicId</th>
                    <th>DeviceId</th>
                    <th>닉네임</th>
                    <th>Google 연동</th>
                    <th>생성일</th>
                    <th>마지막 로그인</th>
                    <th>밴 상태</th>
                    <th>삭제됨</th>
                    <th>병합 대상 ID</th>
                    <th>관리</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in pagedResult.Items)
                {
                    <!-- 소프트 딜리트 계정은 시각적으로 구분 (회색 + 취소선) -->
                    <tr class="@(p.IsDeleted ? "text-muted text-decoration-line-through" : "")">
                        <td>@p.Id</td>
                        <td><code class="small">@p.PublicId</code></td>
                        <td><code>@p.DeviceId</code></td>
                        <td>@p.Nickname</td>
                        <td>@(string.IsNullOrEmpty(p.GoogleId) ? "-" : "연동됨")</td>
                        <td>@p.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td>@p.LastLoginAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <!-- 밴 상태: 정상이면 초록, 밴이면 빨강 -->
                        <td>
                            @if (p.IsBanned)
                            {
                                <span class="text-danger fw-semibold">@GetBanLabel(p)</span>
                            }
                            else
                            {
                                <span class="text-success">정상</span>
                            }
                        </td>
                        <!-- IsDeleted 원시 값 (true/false) -->
                        <td>@(p.IsDeleted ? "true" : "false")</td>
                        <!-- MergedIntoPlayerId 원시 값 (병합 흡수된 대상 PlayerA의 int Id) -->
                        <td>@(p.MergedIntoPlayerId?.ToString() ?? "-")</td>
                        <!-- 밴/밴 해제/삭제 버튼 (소프트 딜리트 계정은 비활성화) -->
                        <td>
                            @if (p.IsDeleted)
                            {
                                <span class="text-muted small">삭제됨</span>
                            }
                            else if (!p.IsBanned)
                            {
                                <button class="btn btn-danger btn-sm" @onclick="() => BanPlayer(p.Id, null)">밴</button>
                                @* 삭제 버튼 — IsDeleted가 false인 경우에만 표시 *@
                                <button class="btn btn-outline-danger btn-sm ms-1" @onclick="() => OpenDeleteModal(p)">삭제</button>
                            }
                            else
                            {
                                <button class="btn btn-outline-secondary btn-sm" @onclick="() => UnbanPlayer(p.Id)">밴 해제</button>
                                @* 밴 상태에서도 삭제 가능 *@
                                <button class="btn btn-outline-danger btn-sm ms-1" @onclick="() => OpenDeleteModal(p)">삭제</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @* 삭제 확인 모달 *@
        <ConfirmDeleteModal IsVisible="showDeleteModal"
                            PlayerInfo="deletingPlayerInfo"
                            OnConfirm="ConfirmDelete"
                            OnCancel="CancelDelete" />

        <!-- 페이지네이션 -->
        <div class="d-flex align-items-center gap-2">
            <button class="btn btn-outline-secondary btn-sm" @onclick="PrevPage" disabled="@(currentPage <= 1)">이전</button>
            <span>@currentPage / @pagedResult.TotalPages 페이지 (총 @pagedResult.TotalCount 건)</span>
            <button class="btn btn-outline-secondary btn-sm" @onclick="NextPage" disabled="@(currentPage >= pagedResult.TotalPages)">다음</button>
        </div>
    }
</section>

<!-- 플레이어 검색 -->
<section class="mb-5">
    <h4>플레이어 검색</h4>
    <div class="d-flex gap-2 mb-2">
        <input type="text" class="form-control" style="max-width: 320px;"
               placeholder="DeviceId 또는 닉네임 일부 입력"
               @bind="searchKeyword"
               @bind:event="oninput"
               @onkeyup="OnSearchKeyUp" />
        <button class="btn btn-secondary" @onclick="SearchByKeyword">검색</button>
        <button class="btn btn-outline-secondary" @onclick="ClearSearch">초기화</button>
    </div>
    @if (isSearchMode)
    {
        @if (searchResults != null && searchResults.Any())
        {
            <p class="text-muted small">검색 결과 @searchResults.Count 건</p>
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>PublicId</th>
                        <th>DeviceId</th>
                        <th>닉네임</th>
                        <th>Google 연동</th>
                        <th>생성일</th>
                        <th>마지막 로그인</th>
                        <th>밴 상태</th>
                        <th>삭제됨</th>
                        <th>병합 대상 ID</th>
                        <th>관리</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in searchResults)
                    {
                        <tr class="@(p.IsDeleted ? "text-muted text-decoration-line-through" : "")">
                            <td>@p.Id</td>
                            <td><code class="small">@p.PublicId</code></td>
                            <td><code>@p.DeviceId</code></td>
                            <td>@p.Nickname</td>
                            <td>@(string.IsNullOrEmpty(p.GoogleId) ? "-" : "연동됨")</td>
                            <td>@p.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                            <td>@p.LastLoginAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                            <!-- 밴 상태: 정상이면 초록, 밴이면 빨강 -->
                            <td>
                                @if (p.IsBanned)
                                {
                                    <span class="text-danger fw-semibold">@GetBanLabel(p)</span>
                                }
                                else
                                {
                                    <span class="text-success">정상</span>
                                }
                            </td>
                            <!-- IsDeleted 원시 값 -->
                            <td>@(p.IsDeleted ? "true" : "false")</td>
                            <!-- MergedIntoPlayerId 원시 값 -->
                            <td>@(p.MergedIntoPlayerId?.ToString() ?? "-")</td>
                            <!-- 밴/밴 해제/삭제 버튼 (소프트 딜리트 계정은 비활성화) -->
                            <td>
                                @if (p.IsDeleted)
                                {
                                    <span class="text-muted small">삭제됨</span>
                                }
                                else if (!p.IsBanned)
                                {
                                    <button class="btn btn-danger btn-sm" @onclick="() => BanPlayer(p.Id, null)">밴</button>
                                    @* 삭제 버튼 — IsDeleted가 false인 경우에만 표시 *@
                                    <button class="btn btn-outline-danger btn-sm ms-1" @onclick="() => OpenDeleteModal(p)">삭제</button>
                                }
                                else
                                {
                                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => UnbanPlayer(p.Id)">밴 해제</button>
                                    @* 밴 상태에서도 삭제 가능 *@
                                    <button class="btn btn-outline-danger btn-sm ms-1" @onclick="() => OpenDeleteModal(p)">삭제</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else if (searchResults != null)
        {
            <p class="text-muted">검색 결과가 없습니다.</p>
        }
        @if (searchError != null)
        {
            <p class="text-danger">@searchError</p>
        }
    }
</section>

<!-- 테스트 계정 등록 (Admin 전용 게스트 계정 생성) -->
<section class="mb-5">
    <h4>테스트 계정 등록</h4>
    <div class="d-flex flex-column gap-2" style="max-width: 400px;">
        <div>
            <label class="form-label">DeviceId</label>
            <div class="d-flex gap-2">
                <input type="text" class="form-control" placeholder="직접 입력 또는 자동 생성" @bind="newDeviceId" />
                <button class="btn btn-outline-secondary" @onclick="GenerateDeviceId" style="white-space: nowrap;">자동 생성</button>
            </div>
            <!-- DeviceId 입력 조건 안내 -->
            <div class="form-text text-muted">영문·숫자만 사용 가능하며 최소 8자 이상이어야 합니다. (예: UUID 형식 권장)</div>
        </div>
        <button class="btn btn-primary" @onclick="RegisterGuest">게스트 등록</button>
    </div>
    @if (registerMessage != null)
    {
        <p class="mt-2 @(registerSuccess ? "text-success" : "text-danger")">@registerMessage</p>
    }
</section>

<style>
    .skeleton-cell {
        display: inline-block;
        width: 80%;
        height: 1rem;
        background: linear-gradient(90deg, #e0e0e0 25%, #f0f0f0 50%, #e0e0e0 75%);
        background-size: 200% 100%;
        animation: shimmer 1.2s infinite;
        border-radius: 4px;
    }
    @@keyframes shimmer {
        0% { background-position: 200% 0; }
        100% { background-position: -200% 0; }
    }
</style>

@code {
    // 전체 목록 (페이지네이션)
    private PlayerPagedResult? pagedResult;
    private int currentPage = 1;
    private const int pageSize = 20;
    private bool isLoading = true;

    // DeviceId/닉네임 검색
    private string searchKeyword = "";
    private List<PlayerDto>? searchResults;
    private string? searchError;
    private bool isSearchMode = false; // 검색 모드 여부 (true이면 검색 결과 패널 표시)

    // 신규 등록
    private string newDeviceId = "";
    private string? registerMessage;
    private bool registerSuccess;

    // 삭제 확인 모달 상태
    private bool showDeleteModal = false;
    private string deletingPlayerInfo = "";
    private int deletingPlayerId = 0;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await SafeExecute(LoadPaged, msg => registerMessage = msg);
            StateHasChanged();
        }
    }

    // 플레이어 목록 조회
    private async Task LoadPaged()
    {
        isLoading = true;
        var client = HttpClientFactory.CreateClient("ApiClient");
        pagedResult = await client.GetFromJsonAsync<PlayerPagedResult>(ApiRoutes.AdminPlayers.Paged(currentPage, pageSize));
        isLoading = false;
    }

    private async Task PrevPage()
    {
        if (currentPage > 1) { currentPage--; await LoadPaged(); }
    }

    private async Task NextPage()
    {
        if (pagedResult != null && currentPage < pagedResult.TotalPages) { currentPage++; await LoadPaged(); }
    }

    // Enter 키 입력 시 검색 실행
    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SearchByKeyword();
    }

    // DeviceId 또는 닉네임 부분 일치 검색
    private async Task SearchByKeyword()
    {
        searchResults = null;
        searchError = null;
        isSearchMode = true;

        if (string.IsNullOrWhiteSpace(searchKeyword))
        {
            // 검색어가 없으면 검색 모드 해제 후 전체 목록 표시
            isSearchMode = false;
            return;
        }

        var client = HttpClientFactory.CreateClient("ApiClient");
        var response = await client.GetAsync(ApiRoutes.AdminPlayers.Search(searchKeyword));

        if (response.IsSuccessStatusCode)
            searchResults = await response.Content.ReadFromJsonAsync<List<PlayerDto>>();
        else
            searchError = "검색 중 오류가 발생했습니다.";
    }

    // 플레이어 밴 처리 — bannedUntil이 null이면 영구 밴
    private async Task BanPlayer(int playerId, DateTime? bannedUntil)
    {
        var client = HttpClientFactory.CreateClient("ApiClient");
        var payload = new { BannedUntil = bannedUntil };
        var response = await client.PostAsJsonAsync(ApiRoutes.AdminPlayers.Ban(playerId), payload);
        if (response.IsSuccessStatusCode)
        {
            // 목록 및 검색 결과 갱신
            await LoadPaged();
            if (isSearchMode && !string.IsNullOrWhiteSpace(searchKeyword))
                await SearchByKeyword();
        }
    }

    // 플레이어 밴 해제
    private async Task UnbanPlayer(int playerId)
    {
        var client = HttpClientFactory.CreateClient("ApiClient");
        var response = await client.PostAsJsonAsync(ApiRoutes.AdminPlayers.Unban(playerId), new { });
        if (response.IsSuccessStatusCode)
        {
            await LoadPaged();
            if (isSearchMode && !string.IsNullOrWhiteSpace(searchKeyword))
                await SearchByKeyword();
        }
    }

    // 삭제 모달 열기 — 대상 플레이어 정보를 상태에 저장
    private void OpenDeleteModal(PlayerDto p)
    {
        deletingPlayerId = p.Id;
        deletingPlayerInfo = $"ID: {p.Id} / 닉네임: {p.Nickname}";
        showDeleteModal = true;
    }

    // 삭제 취소 — 모달 닫기 및 상태 초기화
    private void CancelDelete()
    {
        showDeleteModal = false;
        deletingPlayerId = 0;
        deletingPlayerInfo = "";
    }

    // 삭제 확인 — API 호출 후 목록 갱신
    private async Task ConfirmDelete()
    {
        var client = HttpClientFactory.CreateClient("ApiClient");
        var response = await client.DeleteAsync(ApiRoutes.AdminPlayers.Delete(deletingPlayerId));

        // 모달 닫기 및 상태 초기화
        showDeleteModal = false;
        deletingPlayerId = 0;
        deletingPlayerInfo = "";

        if (response.IsSuccessStatusCode)
        {
            // 삭제 성공 시 전체 목록 및 검색 결과 갱신
            await LoadPaged();
            if (isSearchMode && !string.IsNullOrWhiteSpace(searchKeyword))
                await SearchByKeyword();
        }
    }

    // 검색 초기화 — 전체 목록으로 복귀
    private void ClearSearch()
    {
        searchKeyword = "";
        searchResults = null;
        searchError = null;
        isSearchMode = false;
    }

    // DeviceId 자동 생성
    private void GenerateDeviceId()
    {
        newDeviceId = Guid.NewGuid().ToString();
    }

    // 게스트 등록 — auth/guest 엔드포인트 호출
    private async Task RegisterGuest()
    {
        registerMessage = null;

        if (string.IsNullOrWhiteSpace(newDeviceId))
        {
            registerMessage = "DeviceId를 입력하거나 자동 생성해주세요.";
            registerSuccess = false;
            return;
        }

        // 한글 포함 여부 검사
        if (newDeviceId.Any(c => c >= '가' && c <= '힣' || c >= 'ᄀ' && c <= 'ᇿ' || c >= '㄰' && c <= '㆏'))
        {
            registerMessage = "DeviceId에 한글은 사용할 수 없습니다. 영문·숫자만 입력해주세요.";
            registerSuccess = false;
            return;
        }

        // 최소 길이 검사
        if (newDeviceId.Length < 8)
        {
            registerMessage = "DeviceId는 최소 8자 이상이어야 합니다.";
            registerSuccess = false;
            return;
        }

        var client = HttpClientFactory.CreateClient("ApiClient");
        var payload = new { DeviceId = newDeviceId };
        var response = await client.PostAsJsonAsync(ApiRoutes.Auth.Guest, payload);

        if (response.IsSuccessStatusCode)
        {
            var result = await response.Content.ReadFromJsonAsync<GuestLoginResponse>();
            var status = result?.IsNewPlayer == true ? "신규 생성" : "기존 플레이어";
            registerMessage = $"{status}됨 (PlayerId: {result?.PlayerId})";
            registerSuccess = true;
            newDeviceId = "";
            await LoadPaged();
        }
        else
        {
            registerMessage = "등록에 실패했습니다.";
            registerSuccess = false;
        }
    }

    // 로컬 DTO — IsBanned/BannedUntil + PublicId/소프트 딜리트 정보 포함
    private record PlayerDto(
        int Id,
        Guid PublicId,
        string DeviceId,
        string Nickname,
        string? GoogleId,
        DateTime CreatedAt,
        DateTime LastLoginAt,
        bool IsBanned,
        DateTime? BannedUntil,
        bool IsDeleted,
        DateTime? DeletedAt,
        int? MergedIntoPlayerId);

    private record PlayerPagedResult(List<PlayerDto> Items, int TotalCount, int Page, int PageSize)
    {
        public int TotalPages => (int)Math.Ceiling((double)TotalCount / PageSize);
    }

    private record GuestLoginResponse(string AccessToken, string RefreshToken, Guid PlayerId, bool IsNewPlayer);

    // 밴 상태 표시 문자열 — 기간 밴이면 해제 일시 함께 표기
    private string GetBanLabel(PlayerDto p)
    {
        if (!p.IsBanned) return "정상";
        if (p.BannedUntil.HasValue) return $"밴됨 (~{p.BannedUntil.Value.ToLocalTime():MM-dd HH:mm})";
        return "영구밴";
    }

    // 계정 상태 라벨 — 소프트 딜리트 여부 및 병합 대상 PlayerId 표시
    private string GetAccountStatusLabel(PlayerDto p)
    {
        if (!p.IsDeleted) return "활성";
        var deletedAt = p.DeletedAt?.ToLocalTime().ToString("MM-dd HH:mm") ?? "?";
        if (p.MergedIntoPlayerId.HasValue)
            return $"삭제됨 (→ ID {p.MergedIntoPlayerId}, {deletedAt})";
        return $"삭제됨 ({deletedAt})";
    }
}
