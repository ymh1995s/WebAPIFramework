@page "/items"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inherits SafeComponentBase
@inject IHttpClientFactory HttpClientFactory
@using Framework.Admin.Constants

<PageTitle>아이템 마스터 관리</PageTitle>

<h2>아이템 마스터 관리</h2>

<!-- 아이템 추가 폼 -->
<section class="mb-4">
    <h4>아이템 추가</h4>
    <div class="d-flex gap-2 align-items-end flex-wrap" style="max-width: 1100px;">
        <div>
            <label class="form-label">이름</label>
            <input type="text" class="form-control" @bind="newName" placeholder="아이템 이름" />
        </div>
        <div>
            <label class="form-label">타입</label>
            <select class="form-select" @bind="newItemType">
                @foreach (var type in Enum.GetValues<ItemType>())
                {
                    <option value="@type">@type</option>
                }
            </select>
        </div>
        <div>
            <label class="form-label">설명</label>
            <input type="text" class="form-control" @bind="newDescription" placeholder="설명" style="width:180px;" />
        </div>
        <div>
            <label class="form-label" title="Full: 모든 변동 기록 / AnomalyOnly: 이상치만 기록">감사 레벨</label>
            <select class="form-select" @bind="newAuditLevel">
                @foreach (var level in Enum.GetValues<AuditLevel>())
                {
                    <option value="@level">@level</option>
                }
            </select>
        </div>
        <div>
            <label class="form-label" title="AnomalyOnly에서 이 값 초과 변동 시 이상치 기록. 0이면 검사 안 함">이상치 임계값</label>
            <input type="number" class="form-control" @bind="newAnomalyThreshold" style="width:120px;" />
        </div>
        <button class="btn btn-primary mb-0" @onclick="CreateItem">추가</button>
    </div>
    @if (createMessage != null)
    {
        <p class="mt-2 @(createSuccess ? "text-success" : "text-danger")">@createMessage</p>
    }
</section>

<!-- 삭제 확인 팝업 -->
@if (confirmDeleteId != null)
{
    <div class="modal d-block" style="background:rgba(0,0,0,0.4);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">아이템 삭제 확인</h5>
                </div>
                <div class="modal-body">
                    @if (holderCount > 0)
                    {
                        <p class="text-warning">이 아이템을 보유한 사용자가 <strong>@holderCount</strong>명 있습니다.</p>
                    }
                    <p>그래도 삭제하시겠습니까?</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-danger" @onclick="ConfirmDelete">예</button>
                    <button class="btn btn-secondary" @onclick="CancelDelete">아니오</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- 아이템 목록 -->
<section>
    <h4>아이템 목록</h4>
    @if (isLoading)
    {
        <p>불러오는 중...</p>
    }
    else if (items == null || !items.Any())
    {
        <p class="text-muted">등록된 아이템이 없습니다.</p>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>이름</th>
                    <th>타입</th>
                    <th>설명</th>
                    <th>감사 레벨</th>
                    <th>이상치 임계값</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in items)
                {
                    <tr>
                        <td>@item.Id</td>
                        @if (editingId == item.Id)
                        {
                            <!-- 인라인 수정 모드 -->
                            <td><input type="text" class="form-control form-control-sm" @bind="editName" /></td>
                            <td>
                                <select class="form-select form-select-sm" @bind="editItemType">
                                    @foreach (var type in Enum.GetValues<ItemType>())
                                    {
                                        <option value="@type">@type</option>
                                    }
                                </select>
                            </td>
                            <td><input type="text" class="form-control form-control-sm" @bind="editDescription" /></td>
                            <td>
                                <select class="form-select form-select-sm" @bind="editAuditLevel">
                                    @foreach (var level in Enum.GetValues<AuditLevel>())
                                    {
                                        <option value="@level">@level</option>
                                    }
                                </select>
                            </td>
                            <td><input type="number" class="form-control form-control-sm" @bind="editAnomalyThreshold" /></td>
                            <td>
                                <button class="btn btn-success btn-sm me-1" @onclick="() => SaveEdit(item.Id)">저장</button>
                                <button class="btn btn-secondary btn-sm" @onclick="CancelEdit">취소</button>
                            </td>
                        }
                        else
                        {
                            <td>@item.Name</td>
                            <td>@item.ItemType</td>
                            <td>@item.Description</td>
                            <td>@item.AuditLevel</td>
                            <td>@item.AnomalyThreshold</td>
                            <td>
                                <button class="btn btn-outline-primary btn-sm me-1" @onclick="() => StartEdit(item)">수정</button>
                                <button class="btn btn-outline-danger btn-sm" @onclick="() => RequestDelete(item.Id)">삭제</button>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    }
    @if (listMessage != null)
    {
        <p class="text-danger">@listMessage</p>
    }
</section>

@code {
    // 아이템 목록
    private List<ItemDto>? items;
    private bool isLoading = true;
    private string? listMessage;

    // 추가 폼
    private string newName = "";
    private ItemType newItemType = ItemType.Currency;
    private string newDescription = "";
    private AuditLevel newAuditLevel = AuditLevel.AnomalyOnly;
    private int newAnomalyThreshold = 0;
    private string? createMessage;
    private bool createSuccess;

    // 수정 상태
    private int? editingId;
    private string editName = "";
    private ItemType editItemType;
    private string editDescription = "";
    private AuditLevel editAuditLevel;
    private int editAnomalyThreshold;

    // 삭제 확인 팝업 상태
    private int? confirmDeleteId;
    private int holderCount;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await SafeExecute(LoadItems, msg => listMessage = msg);
            StateHasChanged();
        }
    }

    // 목록 조회
    private async Task LoadItems()
    {
        isLoading = true;
        listMessage = null;
        var client = HttpClientFactory.CreateClient("ApiClient");
        var response = await client.GetAsync(ApiRoutes.AdminItems.Collection);
        if (response.IsSuccessStatusCode)
            items = await response.Content.ReadFromJsonAsync<List<ItemDto>>();
        else
            listMessage = $"목록 조회 실패: {response.StatusCode}";
        isLoading = false;
    }

    // 아이템 생성
    private async Task CreateItem()
    {
        createMessage = null;
        if (string.IsNullOrWhiteSpace(newName))
        {
            createMessage = "이름을 입력해주세요.";
            createSuccess = false;
            return;
        }

        var client = HttpClientFactory.CreateClient("ApiClient");
        var payload = new { Name = newName, ItemType = newItemType, Description = newDescription, AuditLevel = newAuditLevel, AnomalyThreshold = newAnomalyThreshold };
        var response = await client.PostAsJsonAsync(ApiRoutes.AdminItems.Collection, payload);

        if (response.IsSuccessStatusCode)
        {
            createMessage = "추가되었습니다.";
            createSuccess = true;
            newName = "";
            newDescription = "";
            newAnomalyThreshold = 0;
            newAuditLevel = AuditLevel.AnomalyOnly;
            await LoadItems();
        }
        else
        {
            createMessage = "추가에 실패했습니다.";
            createSuccess = false;
        }
    }

    // 수정 시작
    private void StartEdit(ItemDto item)
    {
        editingId = item.Id;
        editName = item.Name;
        editItemType = item.ItemType;
        editDescription = item.Description;
        editAuditLevel = item.AuditLevel;
        editAnomalyThreshold = item.AnomalyThreshold;
    }

    // 수정 취소
    private void CancelEdit()
    {
        editingId = null;
    }

    // 수정 저장
    private async Task SaveEdit(int id)
    {
        var client = HttpClientFactory.CreateClient("ApiClient");
        var payload = new { Name = editName, ItemType = editItemType, Description = editDescription, AuditLevel = editAuditLevel, AnomalyThreshold = editAnomalyThreshold };
        var response = await client.PutAsJsonAsync(ApiRoutes.AdminItems.ById(id), payload);

        if (response.IsSuccessStatusCode)
        {
            editingId = null;
            await LoadItems();
        }
        else
        {
            listMessage = "수정에 실패했습니다.";
        }
    }

    // 삭제 요청 — 보유 유저 수 조회 후 팝업 표시
    private async Task RequestDelete(int id)
    {
        listMessage = null;
        var client = HttpClientFactory.CreateClient("ApiClient");
        var result = await client.GetFromJsonAsync<HolderCountDto>(ApiRoutes.AdminItems.Holders(id));
        holderCount = result?.Count ?? 0;
        confirmDeleteId = id;
    }

    // 삭제 확인
    private async Task ConfirmDelete()
    {
        if (confirmDeleteId == null) return;

        var client = HttpClientFactory.CreateClient("ApiClient");
        var response = await client.DeleteAsync(ApiRoutes.AdminItems.ById(confirmDeleteId!.Value));

        confirmDeleteId = null;

        if (response.IsSuccessStatusCode)
            await LoadItems();
        else
            listMessage = "삭제에 실패했습니다.";
    }

    // 삭제 취소
    private void CancelDelete()
    {
        confirmDeleteId = null;
    }

    // API 응답 매핑용 로컬 DTO
    private record ItemDto(int Id, string Name, ItemType ItemType, string Description, AuditLevel AuditLevel, int AnomalyThreshold);
    private record HolderCountDto(int Count);
    private enum ItemType { Currency, Consumable }
    // 감사 로그 기록 수준 — 서버 Framework.Domain.Enums.AuditLevel와 순서 동일해야 함
    private enum AuditLevel { AnomalyOnly, Full }
}
