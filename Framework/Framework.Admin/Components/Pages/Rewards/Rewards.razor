@page "/rewards"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inherits SafeComponentBase
@using Framework.Admin.Constants

<PageTitle>보상 관리</PageTitle>

<h2>보상 관리</h2>

<!-- ────────────── 빠른 이동 링크 ────────────── -->
<section class="mb-4">
    <div class="d-flex gap-2 flex-wrap">
        <a href="/reward-slots" class="btn btn-outline-primary">월별 보상 설정</a>
    </div>
</section>

<!-- ────────────── 하루 기준 시각 설정 ────────────── -->
<section class="mb-5">
    <h4>하루 기준 시각 (KST)</h4>
    <p class="text-muted small">이 시각 이후 로그인부터 새 날 보상을 받을 수 있습니다. 기본값: 00:00</p>

    <div class="d-flex align-items-end gap-3" style="max-width:400px;">
        <div>
            <label class="form-label">기준 시각</label>
            <!-- HH:mm 형식 time 입력 — 브라우저가 시/분을 분리하여 보여줌 -->
            <input type="time" class="form-control" style="max-width:150px;"
                   value="@boundaryTimeString"
                   @onchange="OnBoundaryTimeChanged" />
        </div>
        <button class="btn btn-primary" @onclick="SaveBoundary">저장</button>
    </div>
    @if (boundaryMessage != null)
    {
        <p class="mt-2 @(boundarySuccess ? "text-success" : "text-danger")">@boundaryMessage</p>
    }
</section>

<!-- ────────────── 월 28회 초과 기본 보상 설정 ────────────── -->
<section class="mb-5">
    <h4>월 28회 초과 기본 보상</h4>
    <p class="text-muted small">이번 달 로그인 횟수가 28회를 초과한 경우 지급할 기본 보상을 설정합니다. 아이템 미설정 또는 수량 0이면 보상 없이 로그만 기록됩니다.</p>

    <div class="d-flex flex-column gap-2" style="max-width:400px;">
        <div>
            <label class="form-label">아이템</label>
            <select class="form-select" @bind="defaultItemIdStr">
                <option value="">아이템 없음 (보상 없음)</option>
                @foreach (var item in itemList)
                {
                    <option value="@item.Id">@item.Name</option>
                }
            </select>
        </div>
        <div>
            <label class="form-label">수량</label>
            <input type="number" class="form-control" min="0" placeholder="예: 10" @bind="defaultItemCount" />
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-primary" @onclick="SaveDefaultReward">저장</button>
            <button class="btn btn-outline-secondary" @onclick="ClearDefaultReward">초기화</button>
        </div>
    </div>
    @if (defaultRewardMessage != null)
    {
        <p class="mt-2 @(defaultRewardSuccess ? "text-success" : "text-danger")">@defaultRewardMessage</p>
    }
</section>

<!-- ────────────── 수동 보상 발송 ────────────── -->
<section class="mb-5">
    <h4>수동 보상 발송</h4>

    <div class="mb-3">
        <div class="form-check form-check-inline">
            <input class="form-check-input" type="radio" name="sendType" id="single" checked="@(sendMode == "single")"
                   @onchange='() => sendMode = "single"' />
            <label class="form-check-label" for="single">특정 플레이어</label>
        </div>
        <div class="form-check form-check-inline">
            <input class="form-check-input" type="radio" name="sendType" id="bulk" checked="@(sendMode == "bulk")"
                   @onchange='() => sendMode = "bulk"' />
            <label class="form-check-label" for="bulk">전체 플레이어</label>
        </div>
    </div>

    <div class="d-flex flex-column gap-2" style="max-width:400px;">
        @if (sendMode == "single")
        {
            <div>
                <label class="form-label">플레이어 ID</label>
                <input type="number" class="form-control" placeholder="예: 42" @bind="targetPlayerId" />
            </div>
        }
        <div>
            <label class="form-label">제목</label>
            <input type="text" class="form-control" placeholder="예: 이벤트 보상" @bind="mailTitle" />
        </div>
        <div>
            <label class="form-label">내용</label>
            <input type="text" class="form-control" placeholder="예: 이벤트 참여 감사합니다." @bind="mailBody" />
        </div>
        <div>
            <label class="form-label">아이템 <span class="text-muted">(선택)</span></label>
            <select class="form-select" @bind="mailItemId">
                <option value="">아이템 없음</option>
                @foreach (var item in itemList)
                {
                    <option value="@item.Id">@item.Name</option>
                }
            </select>
        </div>
        <div>
            <label class="form-label">수량</label>
            <input type="number" class="form-control" min="1" placeholder="예: 10" @bind="mailItemCount" />
        </div>
        <div>
            <label class="form-label">만료일 (일)</label>
            <input type="number" class="form-control" min="1" placeholder="예: 30" @bind="mailExpiresInDays" />
            <div class="form-text">발송 시점 기준 며칠 후까지 수령 가능한지 입력합니다.</div>
        </div>
        <button class="btn btn-primary" @onclick="SendMail">발송</button>
    </div>
    @if (sendMessage != null)
    {
        <p class="mt-2 @(sendSuccess ? "text-success" : "text-danger")">@sendMessage</p>
    }
</section>
