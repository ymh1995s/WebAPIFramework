@page "/reward-slots"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inherits DirtyGuardBase
@using Framework.Admin.Components.Base
@using Framework.Admin.Constants
@using System.Net.Http.Json

<PageTitle>월별 보상 설정</PageTitle>

<h2>월별 보상 설정</h2>
<p class="text-muted">
    Current = 이번 달 활성 슬롯 / Next = 다음 달 예약 슬롯<br />
    월 전환 시 Next → Current 자동 복사됩니다. Admin이 Next를 수정하지 않으면 다음 달도 같은 보상이 반복됩니다.
</p>

<!-- ────────────── 탭 선택 ────────────── -->
<ul class="nav nav-tabs mb-3">
    <li class="nav-item">
        <button class="nav-link @(activeTab == "current" ? "active" : "")"
                @onclick='() => SwitchTab("current")'>
            Current (이번 달)
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(activeTab == "next" ? "active" : "")"
                @onclick='() => SwitchTab("next")'>
            Next (다음 달 예약)
        </button>
    </li>
</ul>

<!-- ────────────── 슬롯 테이블 ────────────── -->
@if (loading)
{
    <p>불러오는 중...</p>
}
else if (errorMessage != null)
{
    <p class="text-danger">@errorMessage</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-bordered table-sm align-middle" style="max-width:560px;">
            <thead class="table-light">
                <tr>
                    <th style="width:60px;">Day</th>
                    <th>아이템</th>
                    <th style="width:90px;">수량</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in slotRows)
                {
                    <!-- 변경된 행은 table-warning으로 시각적 표시 -->
                    <tr class="@(row.IsChanged ? "table-warning" : "")">
                        <td class="text-center fw-bold">@row.Day</td>
                        <td>
                            <!-- 아이템 드롭다운 — 변경 시 dirty 상태 표시 -->
                            <select class="form-select form-select-sm"
                                    value="@(row.EditItemId?.ToString() ?? "")"
                                    @onchange="e => OnItemChanged(row, e)">
                                <option value="">보상 없음</option>
                                @foreach (var item in itemList)
                                {
                                    <option value="@item.Id">@item.Name</option>
                                }
                            </select>
                        </td>
                        <td>
                            <!-- 수량 입력 — 변경 시 dirty 상태 표시 -->
                            <input type="number" class="form-control form-control-sm" min="0"
                                   value="@row.EditItemCount"
                                   disabled="@(!row.EditItemId.HasValue)"
                                   @onchange="e => OnItemCountChanged(row, e)" />
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- 전체 저장 버튼 — 변경사항이 있을 때만 활성화 -->
    <div class="mt-2 d-flex align-items-center gap-3">
        <button class="btn btn-primary"
                @onclick="SaveAll"
                disabled="@(saving || !HasChanges)">
            @(saving ? "저장 중..." : "전체 저장")
        </button>

        @if (saveMessage != null)
        {
            <span class="@(saveSuccess ? "text-success" : "text-danger")">@saveMessage</span>
        }
    </div>
}
