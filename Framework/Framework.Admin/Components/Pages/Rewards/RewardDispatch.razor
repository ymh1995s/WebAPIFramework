@page "/reward-dispatch"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inherits SafeComponentBase
@using Framework.Admin.Constants

<PageTitle>수동 보상/우편 발송</PageTitle>

<h2 class="mb-2">수동 보상/우편 발송</h2>

<!-- 대상 선택 라디오 — 단일 플레이어 또는 전체(Bulk) -->
<div class="mb-3">
    <div class="form-check form-check-inline">
        <input class="form-check-input" type="radio" name="targetMode" id="targetSingle"
               checked="@(targetMode == "single")"
               @onchange='() => OnTargetModeChanged("single")' />
        <label class="form-check-label" for="targetSingle">특정 플레이어</label>
    </div>
    <div class="form-check form-check-inline">
        <input class="form-check-input" type="radio" name="targetMode" id="targetBulk"
               checked="@(targetMode == "bulk")"
               @onchange='() => OnTargetModeChanged("bulk")' />
        <label class="form-check-label" for="targetBulk">전체 플레이어</label>
    </div>
</div>

@if (targetMode == "single")
{
    <!-- 단일 플레이어 — 기존 grant 또는 순수 우편 발송 -->
    <div class="alert alert-warning py-2 small mb-3">
        <strong>주의:</strong> 재화/아이템이 있으면 <code>SourceType=AdminGrant</code>로 보상 지급됩니다.
        동일한 <strong>PlayerId + SourceKey</strong> 조합은 중복 지급되지 않습니다 (멱등성).
        <br />지급 방식: <strong>Auto</strong>이면 아이템이 있을 때 우편, 없으면 즉시 지급됩니다.
    </div>
}
else
{
    <!-- 전체 플레이어 Bulk 우편 발송 안내 -->
    <div class="alert alert-info py-2 small mb-3">
        <strong>전체 발송:</strong> 현재 가입된 모든 플레이어에게 우편을 발송합니다.
        재화(Gold/Gems/Exp) 지급은 지원되지 않습니다. 아이템만 포함하거나 내용만 발송할 수 있습니다.
    </div>
}

<div class="row">
    <div class="col-md-7">
        <section class="card">
            <div class="card-header py-2"><strong>지급/발송 정보 입력</strong></div>
            <div class="card-body">

                <!-- 단일 플레이어일 때만 플레이어 ID 입력 표시 -->
                @if (targetMode == "single")
                {
                    <div class="mb-3">
                        <label class="form-label">플레이어 ID <span class="text-danger">*</span></label>
                        <input type="number" class="form-control form-control-sm" @bind="playerId" placeholder="예: 123" />
                    </div>
                }

                <!-- 단일 플레이어이고 재화/아이템이 있을 때만 SourceKey 필드 표시 -->
                @if (targetMode == "single")
                {
                    <div class="mb-3">
                        <label class="form-label">SourceKey <span class="text-danger">*</span>
                            <small class="text-muted">(중복 방지 키 — 운영 티켓 번호 등)</small>
                        </label>
                        <div class="input-group input-group-sm">
                            <input type="text" class="form-control" @bind="sourceKey" placeholder="예: support-ticket-2026-001" />
                            <button class="btn btn-outline-secondary" type="button" @onclick="GenerateSourceKey">자동 생성</button>
                        </div>
                    </div>
                }

                <!-- 지급 방식 — Bulk 모드에서는 Mail(1)로 고정 -->
                <div class="mb-3">
                    <label class="form-label">지급 방식</label>
                    @if (targetMode == "bulk")
                    {
                        <!-- Bulk는 우편 발송만 지원하므로 잠금 -->
                        <input type="text" class="form-control form-control-sm" value="Mail (우편 지급)" disabled />
                    }
                    else
                    {
                        <select class="form-select form-select-sm" @bind="dispatchMode">
                            <option value="0">Direct (즉시 지급)</option>
                            <option value="1">Mail (우편 지급)</option>
                            <option value="2">Auto (자동 판단) </option>
                        </select>
                        <HelpIcon Text="Direct: 재화(Gold/Gems/Exp)를 PlayerProfile에 즉시 반영합니다. / Mail: 우편함으로 발송하여 수령 시 지급합니다. / Auto: 재화만 있으면 Direct, 아이템이 포함되면 Mail로 자동 분기합니다." />
                    }
                </div>

                <!-- 재화 지급 — Bulk 모드에서는 숨김 (Bulk 재화 미지원) -->
                @if (targetMode == "single")
                {
                    <div class="card mb-3">
                        <div class="card-header py-1 small"><strong>재화</strong></div>
                        <div class="card-body py-2">
                            <div class="row g-2">
                                <div class="col-4">
                                    <label class="form-label small mb-1">Gold</label>
                                    <input type="number" class="form-control form-control-sm" @bind="gold" min="0" />
                                </div>
                                <div class="col-4">
                                    <label class="form-label small mb-1">Gems</label>
                                    <input type="number" class="form-control form-control-sm" @bind="gems" min="0" />
                                </div>
                                <div class="col-4">
                                    <label class="form-label small mb-1">Exp</label>
                                    <input type="number" class="form-control form-control-sm" @bind="exp" min="0" />
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <!-- 아이템 지급 -->
                <div class="card mb-3">
                    <div class="card-header py-1 small d-flex justify-content-between align-items-center">
                        <strong>아이템</strong>
                        <button class="btn btn-outline-secondary btn-sm" @onclick="AddItem">+ 추가</button>
                    </div>
                    <div class="card-body py-2">
                        @if (targetMode == "bulk")
                        {
                            <p class="small text-warning mb-1">Bulk 모드에서는 첫 번째 아이템만 적용됩니다.</p>
                        }
                        @if (!items.Any())
                        {
                            <p class="small text-muted mb-0">아이템 없음 (재화만 지급)</p>
                        }
                        @foreach (var item in items)
                        {
                            <div class="row g-2 mb-1 align-items-center">
                                <div class="col-5">
                                    <input type="number" class="form-control form-control-sm" @bind="item.ItemId" placeholder="ItemId" />
                                </div>
                                <div class="col-4">
                                    <input type="number" class="form-control form-control-sm" @bind="item.Quantity" min="1" placeholder="수량" />
                                </div>
                                <div class="col-3">
                                    <button class="btn btn-outline-danger btn-sm w-100" @onclick="() => RemoveItem(item)">×</button>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- 우편 설정
                     - 단일 플레이어: Direct(0)이 아닐 때 표시
                     - Bulk 모드: 항상 표시 (우편만 지원)
                     - 단일 플레이어 + 재화/아이템 없음(순수 우편): 안내 문구 표시 -->
                @if (targetMode == "bulk" || (targetMode == "single" && dispatchMode != "0"))
                {
                    <div class="card mb-3">
                        <div class="card-header py-1 small">
                            <strong>우편 설정</strong>
                            @if (targetMode == "single")
                            {
                                <span class="text-muted"> (Mail 모드 또는 Auto에서 아이템 있을 때 사용)</span>
                            }
                        </div>
                        <div class="card-body py-2">
                            @if (targetMode == "single" && IsPureMail())
                            {
                                <!-- 재화/아이템 없이 우편만 발송할 경우 안내 -->
                                <div class="alert alert-secondary py-1 small mb-2">
                                    재화/아이템 없는 우편은 보상 지급 이력에 기록되지 않습니다.
                                </div>
                            }
                            <div class="mb-2">
                                <label class="form-label small mb-1">제목</label>
                                <input type="text" class="form-control form-control-sm" @bind="mailTitle" placeholder="운영팀 보상이 도착했습니다" />
                            </div>
                            <div class="mb-2">
                                <label class="form-label small mb-1">본문</label>
                                <textarea class="form-control form-control-sm" @bind="mailBody" rows="2" placeholder="운영팀에서 보상을 지급했습니다."></textarea>
                            </div>
                            <div>
                                <label class="form-label small mb-1">만료 (일)</label>
                                <input type="number" class="form-control form-control-sm" @bind="mailExpiresInDays" min="1" max="365" style="width:100px" />
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div class="card-footer py-2">
                <button class="btn btn-primary btn-sm" @onclick="Execute">
                    @(targetMode == "bulk" ? "전체 발송" : "지급 실행")
                </button>
            </div>
        </section>
    </div>

    <div class="col-md-5">
        @if (!string.IsNullOrEmpty(resultMessage))
        {
            <div class="alert @(resultSuccess ? "alert-success" : "alert-danger") mt-2">
                @resultMessage
                @if (resultDetail is not null)
                {
                    <hr />
                    <div class="small">
                        <div>사용된 방식: <strong>@resultDetail.UsedMode</strong></div>
                        @if (resultDetail.MailId.HasValue)
                        {
                            <div>MailId: <strong>@resultDetail.MailId</strong></div>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>
