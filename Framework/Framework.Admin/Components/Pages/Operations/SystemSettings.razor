@page "/system-settings"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inherits SafeComponentBase
@using Framework.Admin.Constants

<PageTitle>시스템 설정</PageTitle>

<div class="d-flex align-items-center gap-3 mb-3">
    <h2 class="mb-0">시스템 설정</h2>
    <span class="badge @(isUnderMaintenance ? "bg-danger" : "bg-success") fs-6">
        @(isUnderMaintenance ? "점검 중" : "정상 운영 중")
    </span>
    <button class="btn btn-outline-secondary btn-sm" @onclick="LoadSettings">새로고침</button>
</div>

@if (isLoading)
{
    <p>불러오는 중...</p>
}
else
{
    <!-- 점검 모드 수동 토글 -->
    <section class="mb-5">
        <h4>점검 모드 (수동)</h4>
        <p class="text-muted small">즉시 켜고 끕니다. Admin을 제외한 모든 API가 503을 반환합니다.</p>
        <div class="form-check form-switch">
            <input class="form-check-input" type="checkbox" role="switch" id="maintenanceToggle"
                   checked="@maintenanceEnabled" @onchange="ToggleMaintenance" />
            <label class="form-check-label @(maintenanceEnabled ? "text-danger fw-bold" : "")" for="maintenanceToggle">
                @(maintenanceEnabled ? "점검 중" : "정상 운영 중")
            </label>
        </div>
        @if (maintenanceMessage != null)
        {
            <p class="mt-1 @(maintenanceEnabled ? "text-danger" : "text-success")">@maintenanceMessage</p>
        }
    </section>

    <!-- 점검 예약 -->
    <section class="mb-5">
        <h4>점검 예약</h4>
        <p class="text-muted small">설정한 시간 범위에 자동으로 점검 모드가 적용됩니다. (KST 기준 입력)</p>
        <div class="d-flex gap-3 align-items-end flex-wrap mb-2">
            <div>
                <label class="form-label">시작 시각</label>
                <div class="d-flex gap-1">
                    <input type="date" class="form-control" value="@scheduleStartDate" @onchange="e => scheduleStartDate = e.Value?.ToString()" />
                    <input type="time" class="form-control" value="@scheduleStartTime" @onchange="e => scheduleStartTime = e.Value?.ToString()" />
                </div>
            </div>
            <div>
                <label class="form-label">종료 시각</label>
                <div class="d-flex gap-1">
                    <input type="date" class="form-control" value="@scheduleEndDate" @onchange="e => scheduleEndDate = e.Value?.ToString()" />
                    <input type="time" class="form-control" value="@scheduleEndTime" @onchange="e => scheduleEndTime = e.Value?.ToString()" />
                </div>
            </div>
            <button class="btn btn-primary" @onclick="SaveSchedule">저장</button>
            <button class="btn btn-outline-secondary" @onclick="ClearSchedule">초기화</button>
        </div>
        @if (currentStartAt.HasValue && currentEndAt.HasValue)
        {
            <p class="text-muted small">
                현재 예약: @currentStartAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ~ @currentEndAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm") (KST)
            </p>
        }
        else
        {
            <p class="text-muted small">현재 예약 없음</p>
        }
        @if (scheduleMessage != null)
        {
            <p class="mt-1 text-success">@scheduleMessage</p>
        }
    </section>

    <!-- 클라이언트 앱 버전 설정 (서버 버전 아님) -->
    <section class="mb-5">
        <h4>클라이언트 앱 버전 관리</h4>
        <p class="text-muted small">
            앱스토어(Google Play / App Store)에 배포된 Unity 클라이언트 빌드 버전을 관리합니다.
            서버 버전과 무관하며, 게임 앱을 새 버전으로 배포할 때 이 값을 함께 업데이트하세요.
        </p>
        <div class="d-flex gap-4 align-items-start flex-wrap mb-2">
            <div>
                <label class="form-label fw-semibold">최소 지원 버전 <span class="badge bg-danger ms-1">강제 업데이트 기준</span></label>
                <input type="text" class="form-control" placeholder="예: 1.0.0"
                       value="@minVersion" @onchange="e => minVersion = e.Value?.ToString() ?? string.Empty" />
                <div class="form-text">이 버전 미만의 클라이언트는 앱스토어 업데이트를 강제로 안내받습니다.</div>
            </div>
            <div>
                <label class="form-label fw-semibold">최신 버전 <span class="badge bg-secondary ms-1">소프트 업데이트 안내</span></label>
                <input type="text" class="form-control" placeholder="예: 1.2.0"
                       value="@latestVersion" @onchange="e => latestVersion = e.Value?.ToString() ?? string.Empty" />
                <div class="form-text">현재 앱스토어에 올라간 최신 버전. 클라이언트가 업데이트 안내 팝업에 활용합니다.</div>
            </div>
            <div class="d-flex align-items-end" style="padding-bottom: 1px;">
                <button class="btn btn-primary" @onclick="SaveVersion">저장</button>
            </div>
        </div>
        @if (versionMessage != null)
        {
            <p class="mt-1 text-success">@versionMessage</p>
        }
    </section>

    <!-- 일일 보상 — 하루 기준 시각 설정 (/rewards에서 이전) -->
    <section class="mb-5">
        <h4>일일 보상 — 하루 기준 시각 (KST)</h4>
        <p class="text-muted small">이 시각 이후 로그인부터 새 날 보상을 받을 수 있습니다. 기본값: 00:00</p>

        <div class="d-flex align-items-end gap-3" style="max-width:400px;">
            <div>
                <label class="form-label">기준 시각</label>
                <!-- HH:mm 형식 time 입력 — 브라우저가 시/분을 분리하여 보여줌 -->
                <input type="time" class="form-control" style="max-width:150px;"
                       value="@boundaryTimeString"
                       @onchange="OnBoundaryTimeChanged" />
            </div>
            <button class="btn btn-primary" @onclick="SaveBoundary">저장</button>
        </div>
        @if (boundaryMessage != null)
        {
            <p class="mt-2 @(boundarySuccess ? "text-success" : "text-danger")">@boundaryMessage</p>
        }
    </section>

    <!-- 일일 보상 — 월 28회 초과 기본 보상 설정 (/rewards에서 이전) -->
    <section class="mb-5">
        <h4>일일 보상 — 월 28회 초과 기본 보상</h4>
        <p class="text-muted small">이번 달 로그인 횟수가 28회를 초과한 경우 지급할 기본 보상을 설정합니다. 아이템 미설정 또는 수량 0이면 보상 없이 로그만 기록됩니다.</p>

        <div class="d-flex flex-column gap-2" style="max-width:400px;">
            <div>
                <label class="form-label">아이템</label>
                <select class="form-select" @bind="defaultItemIdStr">
                    <option value="">아이템 없음 (보상 없음)</option>
                    @foreach (var item in itemList)
                    {
                        <option value="@item.Id">@item.Name</option>
                    }
                </select>
            </div>
            <div>
                <label class="form-label">수량</label>
                <input type="number" class="form-control" min="0" placeholder="예: 10" @bind="defaultItemCount" />
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-primary" @onclick="SaveDefaultReward">저장</button>
                <button class="btn btn-outline-secondary" @onclick="ClearDefaultReward">초기화</button>
            </div>
        </div>
        @if (defaultRewardMessage != null)
        {
            <p class="mt-2 @(defaultRewardSuccess ? "text-success" : "text-danger")">@defaultRewardMessage</p>
        }
    </section>
}

@if (errorMessage != null)
{
    <p class="text-danger">@errorMessage</p>
}
