@page "/rate-limit-logs"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inherits SafeComponentBase
@using Framework.Admin.Constants

<PageTitle>보안 감시</PageTitle>

<h2>보안 감시</h2>

<!-- 탭 전환 -->
<ul class="nav nav-tabs mb-4">
    <li class="nav-item">
        <button class="nav-link @(activeTab == "timeline" ? "active" : "")" @onclick='() => activeTab = "timeline"'>
            통합 타임라인
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(activeTab == "ip" ? "active" : "")" @onclick='() => activeTab = "ip"'>
            IP 집계
        </button>
    </li>
</ul>

<!-- 통합 타임라인 탭 -->
@if (activeTab == "timeline")
{
    <div class="alert alert-info py-2 mb-3" role="alert">
        <strong>통합 보안 타임라인:</strong>
        Rate Limit 초과, 재화 이상치, 계정 정지 이벤트를 한 화면에서 확인합니다.
    </div>

    <!-- 필터 -->
    <div class="row g-2 mb-3">
        <div class="col-auto">
            <label class="form-label mb-0 small">시작일</label>
            <input type="date" class="form-control form-control-sm" @bind="filterFrom" />
        </div>
        <div class="col-auto">
            <label class="form-label mb-0 small">종료일</label>
            <input type="date" class="form-control form-control-sm" @bind="filterTo" />
        </div>
        <div class="col-auto">
            <label class="form-label mb-0 small">PlayerId</label>
            <input type="number" class="form-control form-control-sm" style="width:110px" @bind="filterPlayerId" placeholder="숫자 입력" />
        </div>
        <div class="col-auto">
            <label class="form-label mb-0 small">IP</label>
            <input type="text" class="form-control form-control-sm" style="width:150px" @bind="filterIp" placeholder="예) 1.2.3.4" />
        </div>
        <div class="col-auto align-self-end">
            <button class="btn btn-primary btn-sm" @onclick="LoadTimeline">조회</button>
        </div>
    </div>

    @if (isTimelineLoading)
    {
        <p>불러오는 중...</p>
    }
    else if (timelineItems == null)
    {
        <p class="text-muted">조회 버튼을 눌러주세요.</p>
    }
    else if (!timelineItems.Any())
    {
        <p class="text-muted">해당 기간에 보안 이벤트가 없습니다.</p>
    }
    else
    {
        <table class="table table-sm table-striped">
            <thead>
                <tr>
                    <th>시각 (KST)</th>
                    <th>유형</th>
                    <th>심각도</th>
                    <th>PlayerId</th>
                    <th>IP</th>
                    <th>설명</th>
                    <th>관리</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in timelineItems)
                {
                    <tr>
                        <td class="text-nowrap">@ToKst(item.OccurredAt).ToString("MM-dd HH:mm:ss")</td>
                        <td>
                            @if (item.Type == "RateLimit")
                            {
                                <span class="badge bg-warning text-dark">RateLimit</span>
                            }
                            else if (item.Type == "Anomaly")
                            {
                                <span class="badge bg-orange text-white" style="background-color:#fd7e14!important">Anomaly</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Ban</span>
                            }
                        </td>
                        <td>
                            @if (item.Severity == "Critical")
                            {
                                <span class="text-danger fw-bold">Critical</span>
                            }
                            else
                            {
                                <span class="text-warning fw-semibold">Warn</span>
                            }
                        </td>
                        <td>
                            @(item.PlayerId?.ToString() ?? "-")
                            @if (item.PlayerId.HasValue && item.IsBanned)
                            {
                                <span class="badge bg-secondary ms-1">밴됨</span>
                            }
                        </td>
                        <td>@(item.IpAddress ?? "-")</td>
                        <td>@item.Description</td>
                        <td>
                            @if (item.PlayerId.HasValue && item.Type != "Ban" && !item.IsBanned)
                            {
                                <button class="btn btn-danger btn-sm"
                                        disabled="@banningPlayerIds.Contains(item.PlayerId.Value)"
                                        @onclick="() => BanFromTimeline(item.PlayerId!.Value)">
                                    영구밴
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <p class="text-muted small">최대 200건 표시</p>
    }

    @if (timelineError != null)
    {
        <p class="text-danger">@timelineError</p>
    }
}

<!-- IP 집계 탭 (기존 뷰 유지) -->
@if (activeTab == "ip")
{
    <div class="alert alert-info py-2 mb-4" role="alert">
        <strong>로그 기록 조건 (429 발생 시 자동 기록):</strong><br/>
        <span>· <strong>auth 정책</strong>: 동일 IP가 인증 엔드포인트(<code>/auth/*</code>) 전체에 <strong>1분 내 @(authPermitLimit > 0 ? authPermitLimit : "?")회 초과</strong></span>
    </div>

    <div class="d-flex gap-2 align-items-center mb-3">
        <button class="btn btn-primary" @onclick="LoadLogs">조회</button>
    </div>

    @if (isLoading)
    {
        <p>불러오는 중...</p>
    }
    else if (logs == null)
    {
        <p class="text-muted">조회 버튼을 눌러주세요.</p>
    }
    else if (!logs.Any())
    {
        <p class="text-muted">Rate Limit 초과 기록이 없습니다.</p>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>IP</th>
                    <th>초과 횟수</th>
                    <th>마지막 발생 (KST)</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in logs)
                {
                    <tr>
                        <td>@log.IpAddress</td>
                        <td><span class="badge bg-danger">@log.Count</span></td>
                        <td>@ToKst(log.LastOccurredAt).ToString("yyyy-MM-dd HH:mm:ss")</td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (loadError != null)
    {
        <p class="text-danger">@loadError</p>
    }

    <!-- 침투 시도 테스트 섹션 -->
    <section class="mb-4 mt-4">
        <h4>침투 시도 테스트</h4>
        <p class="text-muted small">
            auth 엔드포인트에 <strong>@(authPermitLimit > 0 ? authPermitLimit + 5 : 65)회</strong> 연속 요청을 보내
            Rate Limit(<strong>@(authPermitLimit > 0 ? authPermitLimit : "?")회/분</strong>)을 고의로 초과시킵니다.
        </p>
        <button class="btn btn-danger" @onclick="RunAttackTest" disabled="@isAttacking">
            @(isAttacking ? "시도 중..." : "침투 시도")
        </button>

        @if (attackResults.Any())
        {
            <div class="mt-3">
                <table class="table table-sm table-bordered" style="max-width:400px;">
                    <thead>
                        <tr>
                            <th>시도</th>
                            <th>응답</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in attackResults)
                        {
                            <tr class="@(r.Status == 429 ? "table-danger" : "table-success")">
                                <td>@r.Index</td>
                                <td>@r.Status @r.Label</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
}
