@page "/rate-limit-logs"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inherits SafeComponentBase
@using Framework.Admin.Constants

<PageTitle>보안 감시</PageTitle>

<h2>보안 감시</h2>

<!-- 로그 기록 조건 안내 -->
<div class="alert alert-info py-2 mb-4" role="alert">
    <strong>로그 기록 조건:</strong>
    동일 IP가 인증 엔드포인트(<code>/auth/guest</code>)에 <strong>1분 내 10회를 초과</strong>하여 요청할 경우 자동으로 기록됩니다.<br/>
    <span class="text-muted small">IP별 누적 초과 횟수와 마지막 발생 시각(KST)을 확인할 수 있습니다.</span>
</div>

<!-- 로그 조회 섹션 -->
<section class="mb-4">
    <div class="d-flex gap-2 align-items-center mb-3">
        <button class="btn btn-primary" @onclick="LoadLogs">조회</button>
    </div>

    @if (isLoading)
    {
        <p>불러오는 중...</p>
    }
    else if (logs == null)
    {
        <p class="text-muted">조회 버튼을 눌러주세요.</p>
    }
    else if (!logs.Any())
    {
        <p class="text-muted">Rate Limit 초과 기록이 없습니다.</p>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>IP</th>
                    <th>초과 횟수</th>
                    <th>마지막 발생 (KST)</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in logs)
                {
                    <tr>
                        <td>@log.IpAddress</td>
                        <td><span class="badge bg-danger">@log.Count</span></td>
                        <td>@TimeZoneInfo.ConvertTimeFromUtc(log.LastOccurredAt, TimeZoneInfo.FindSystemTimeZoneById("Asia/Seoul")).ToString("yyyy-MM-dd HH:mm:ss")</td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (loadError != null)
    {
        <p class="text-danger">@loadError</p>
    }
</section>

<!-- 침투 시도 테스트 섹션 -->
<section class="mb-4">
    <h4>침투 시도 테스트</h4>
    <p class="text-muted small">auth 엔드포인트에 15회 연속 요청을 보내 Rate Limit(10회/분)을 고의로 초과시킵니다.</p>
    <button class="btn btn-danger" @onclick="RunAttackTest" disabled="@isAttacking">
        @(isAttacking ? "시도 중..." : "침투 시도")
    </button>

    @if (attackResults.Any())
    {
        <div class="mt-3">
            <table class="table table-sm table-bordered" style="max-width:400px;">
                <thead>
                    <tr>
                        <th>시도</th>
                        <th>응답</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in attackResults)
                    {
                        <tr class="@(r.Status == 429 ? "table-danger" : "table-success")">
                            <td>@r.Index</td>
                            <td>@r.Status @r.Label</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
