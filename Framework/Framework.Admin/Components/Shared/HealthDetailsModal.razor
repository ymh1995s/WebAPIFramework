@* API 서버 상태 상세 모달 — ConfirmDeleteModal 패턴(JS 미사용 순수 Blazor 조건 렌더링) *@

@if (IsVisible)
{
    @* 반투명 백드롭 — 모달 뒤 UI 클릭 방지 *@
    <div style="position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:1040;" @onclick="HandleClose"></div>

    @* 모달 본체 *@
    <div class="modal d-block" tabindex="-1" style="z-index:1050;">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">

                @* 모달 헤더 — 전체 상태 배지 포함 *@
                <div class="modal-header">
                    <h5 class="modal-title">API 서버 상태</h5>
                    @if (!IsOffline && Data is not null)
                    {
                        @* 전체 상태 배지 — Healthy/Degraded/Unhealthy *@
                        <span class="badge ms-2 @StatusBadgeClass(Data.Status)">@Data.Status</span>
                    }
                    else if (IsOffline)
                    {
                        <span class="badge ms-2 bg-dark">Offline</span>
                    }
                </div>

                @* 모달 바디 *@
                <div class="modal-body">
                    @* 메타 정보 — 마지막 확인 시각 및 전체 응답 시간 *@
                    <div class="text-muted small mb-3">
                        <span>마지막 확인: @(LastCheckedAt?.ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</span>
                        @if (!IsOffline && Data is not null)
                        {
                            <span class="ms-3">응답 시간: @($"{Data.TotalDuration:F1}")ms</span>
                        }
                    </div>

                    @if (IsOffline)
                    {
                        @* Offline 상태 — 연결 불가 메시지만 표시 *@
                        <div class="alert alert-dark">
                            <strong>API 서버에 연결할 수 없습니다.</strong>
                            <div class="small mt-1">마지막 시도: @(LastCheckedAt?.ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</div>
                        </div>
                    }
                    else if (Data?.Checks is { Length: > 0 })
                    {
                        @* 의존성별 헬스체크 테이블 *@
                        <table class="table table-sm table-bordered mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>이름</th>
                                    <th>상태</th>
                                    <th>응답 시간</th>
                                    <th>설명</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var check in Data.Checks)
                                {
                                    <tr>
                                        <td>@check.Name</td>
                                        <td>
                                            @* 항목별 상태 배지 *@
                                            <span class="badge @StatusBadgeClass(check.Status)">@check.Status</span>
                                        </td>
                                        <td>@($"{check.Duration:F1}")ms</td>
                                        <td class="text-muted small">@(check.Description ?? "-")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else if (Data is not null)
                    {
                        <p class="text-muted">체크 항목이 없습니다.</p>
                    }
                </div>

                @* 모달 푸터 — 새로고침 / 닫기 버튼 *@
                <div class="modal-footer">
                    <button class="btn btn-outline-primary btn-sm" @onclick="HandleRefresh">새로고침</button>
                    <button class="btn btn-secondary btn-sm" @onclick="HandleClose">닫기</button>
                </div>

            </div>
        </div>
    </div>
}

@code {
    /// <summary>모달 표시 여부</summary>
    [Parameter] public bool IsVisible { get; set; }

    /// <summary>헬스체크 응답 데이터 — null이면 아직 미수신 또는 Offline</summary>
    [Parameter] public HealthResponse? Data { get; set; }

    /// <summary>마지막 확인 시각 — 메타 정보 표시용</summary>
    [Parameter] public DateTime? LastCheckedAt { get; set; }

    /// <summary>Offline 여부 — 연결 불가 메시지 분기용</summary>
    [Parameter] public bool IsOffline { get; set; }

    /// <summary>새로고침 버튼 콜백 — HealthIndicator의 LoadAsync 호출</summary>
    [Parameter] public EventCallback OnRefresh { get; set; }

    /// <summary>닫기 버튼 콜백 — HealthIndicator의 CloseModal 호출</summary>
    [Parameter] public EventCallback OnClose { get; set; }

    // 상태 문자열 → Bootstrap 배지 색상 클래스 매핑
    private static string StatusBadgeClass(string status) => status.ToLowerInvariant() switch
    {
        "healthy"   => "bg-success",
        "degraded"  => "bg-warning text-dark",
        "unhealthy" => "bg-danger",
        _           => "bg-secondary"
    };

    // 새로고침 버튼 클릭 — 부모 LoadAsync 호출
    private async Task HandleRefresh() => await OnRefresh.InvokeAsync();

    // 닫기 버튼 또는 백드롭 클릭 — 모달 닫기
    private async Task HandleClose() => await OnClose.InvokeAsync();
}
