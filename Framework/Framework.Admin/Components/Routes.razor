<Router AppAssembly="typeof(Program).Assembly" NotFoundPage="typeof(Pages.Errors.NotFound)">
    <Found Context="routeData">
        <!-- 인증 필요 라우트 뷰 - 미인증 시 NotAuthorized 블록 표시 -->
        <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)">
            <NotAuthorized>
                <!-- 초기 HTTP 요청은 쿠키 인증이 /login으로 자동 리다이렉트 처리
                     Blazor 회로 내 클라이언트 사이드 이동의 경우 아래 링크 표시 -->
                <div style="margin: 80px auto; max-width: 360px; text-align: center;">
                    <p>인증이 필요합니다.</p>
                    <a href="/login" class="btn btn-primary">로그인</a>
                </div>
            </NotAuthorized>
        </AuthorizeRouteView>
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
</Router>
