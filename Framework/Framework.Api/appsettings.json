{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "MatchMaking": {
    "MaxPlayers": 4
  },
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=framework_db;Username=postgres;Password=postgres"
  },
  "Admin": {
    "ApiKey": "change-this-admin-key-in-production"
  },
  "Google": {
    "ClientId": "your-google-client-id.apps.googleusercontent.com"
  },
  "Jwt": {
    "SecretKey": "change-this-to-a-very-long-secret-key-in-production-32chars+",
    "Issuer": "FrameworkApi",
    "Audience": "FrameworkClient"
  }
}
