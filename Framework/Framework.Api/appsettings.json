{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "MatchMaking": {
    "MaxPlayers": 4
  },
  "RateLimiting": {
    "AuthPermitLimit": 60,
    "AdsCallbackPermitLimit": 300,
    "IapRtdnPermitLimit": 600
  },
  "AdNetworks": {
    "UnityAds": {
      "SecretKey": "UNITY_ADS_SECRET_KEY from .env"
    },
    "IronSource": {
      "SecretKey": "IRONSOURCE_SECRET_KEY from .env"
    }
  },
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=framework_db;Username=postgres;Password=POSTGRES_PASSWORD from .env"
  },
  "Admin": {
    "ApiKey": "ADMIN_API_KEY from .env"
  },
  "Google": {
    "ClientId": "GOOGLE_CLIENT_ID from .env"
  },
  "Iap": {
    "Google": {
      "PackageName": "com.yourcompany.yourgame",
      "ServiceAccountJsonPath": "secrets/google-play-service-account.json",
      "RtdnAudience": "https://your-server.com/api/iap/google/rtdn"
    }
  },
  "Jwt": {
    "SecretKey": "JWT_SECRET_KEY from .env",
    "Issuer": "FrameworkApi",
    "Audience": "FrameworkClient"
  }
}
